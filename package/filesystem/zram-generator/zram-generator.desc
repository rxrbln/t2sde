[I] Systemd unit generator for zram devices

[T] Systemd unit generator for zram devices.

[U] https://github.com/systemd/zram-generator

[A] systemd
[M] René Rebe <rene@exactco.de>

[C] extra/tool
[F] CROSS

[L] MIT
[V] 1.2.1

[D] 54a3b8bc32646d57e0cc947aec504d7a6c1d15b7c521dff22b7b276f zram-generator-1.2.1.tar.gz https://github.com/systemd/zram-generator/archive/v1.2.1/

runconf=0 runcargo=0

makeopt="DESTDIR=$root"
makeinstopt="DESTDIR=$root install"

hook_add premake 5 "sed -i 's,man/zram-generator\.conf\.5,man/zram-generator.5,' Makefile"
