if ! pkginstalled nvidia; then
	export USE_NCCL=OFF
	export USE_SYSTEM_NCCL=OFF
	export USE_CUDA=0
	export USE_CUDNN=0
fi
if ! pkginstalled rocm-llvm; then
	export USE_ROCM=0
fi
