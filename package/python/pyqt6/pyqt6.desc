[C] extra/tool
[F] CROSS

[L] GPL
[V] 6.10.2
[P] X -----5---9 400.000

[E] add pyqt6-sip pyqt-builder
[E] opt qt63d qt6charts qt6connectivity qt6datavis3d qt6graphs qt6shadertools
[E] opt qt6httpserver qt6location qt6multimedia qt6networkauth qt6webview
[E] opt qt6positioning qt6quick3d qt6remoteobjects qt6scxml qt6sensors
[E] opt qt6speech qt6svg qt6tools qt6webchannel qt6webengine qt6websockets

[D] c97f1edc995a364243e4cdba43708b8c2c0b0ecd7656c5c6c1903396 pyqt6-6.10.2.tar.gz https://files.pythonhosted.org/packages/source/p/pyqt6/

export PATH=/$(pkgprefix bindir qt6base):$PATH
var_append GCC_WRAPPER_APPEND ' ' -I$root$(pkgprefix includedir qt6base)
var_append GCC_WRAPPER_APPEND ' ' -I$root$(pkgprefix includedir qt6base)/QtCore

sip_parallel() {
cat << EOF >> pyproject.toml

[tool.sip.builder]
jobs = $SDECFG_PARALLEL
EOF
}

hook_add preconf 5 sip_parallel
