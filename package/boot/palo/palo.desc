[I] PA-RISC bootLOader

[T] PALO (PA-RISC bootLOader) is the bootloader used by the HPPA port of Linux.

[U] https://git.kernel.org/pub/scm/linux/kernel/git/deller/palo.git/

[A] Helge Deller <deller@gmx.de>
[M] René Rebe <rene@exactco.de>

[C] base/boot
[F] CROSS DIETLIBC NO-LTO
[R] + hppa hppa64

[L] GPL
[V] 2.30

[P] X ?----5---9

[D] 2356697001f8a10936b024630acd0da3a7ff1a522407093dacde4ab2 palo-2.30.tar.gz https://git.kernel.org/pub/scm/linux/kernel/git/deller/palo.git/snapshot/

atstage toolchain || hook_add premake 1 'rm -vf iplboot' # build iplboot!
atstage toolchain || hook_add inmake 5 'eval $MAKE $makeopt -j1 iplboot'
[ $stagelevel = 2 ] && hook_add premake 5 '(cd palo; eval $MAKE $makeopt CC=cc mkbootable; mv mkbootable ..; rm *.o)'

var_append makeinstopt ' ' DESTDIR=$root
atstage cross && var_append makeinstopt ' ' HELP2MAN=
pkginstalled perl || var_append makeinstopt ' ' HELP2MAN=
