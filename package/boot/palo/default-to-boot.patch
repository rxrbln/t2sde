As I nearly never need '0' to edit the kernel, let's default to a
IMHO much more reasonable 'b' to boot.

--- palo-2.24/ipl/ipl.c.vanilla	2024-04-06 13:50:21.630969647 +0200
+++ palo-2.24/ipl/ipl.c	2024-04-06 13:51:58.863969220 +0200
@@ -406,7 +406,7 @@
 	    "'d'           toggle debug mode\n"
 #endif
 	    "? ");
-	numbuf[0] = '0';
+	numbuf[0] = 'b';
 	numbuf[1] = '\0';
 	enter_text(numbuf, sizeof numbuf - 1);
 	printf("\n");
