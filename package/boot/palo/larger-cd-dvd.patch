Upstream palo erors out creating bootable ISOs larger than 800MB.
Increase that for 2GB for now. More might need more tweaks.

--- palo-2.24/palo/palo.c.vanilla	2023-12-12 22:16:24.689714475 +0100
+++ palo-2.24/palo/palo.c	2023-12-12 22:17:13.030710188 +0100
@@ -378,7 +378,7 @@
     struct firstblock f;
     /* always load IPL at second 2k block on sequential media */
     int where = 1 * FW_BLOCKSIZE;
-    unsigned end = 800 * 1024 * 1024;
+    unsigned end = 2000 * 1024 * 1024;
     /* int is safe since CD-ROM is < 2G */
     int bootloader_offset;
     int kernel32_offset;
