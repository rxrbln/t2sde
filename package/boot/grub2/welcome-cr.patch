Some PC BIOS' (like ASRock B550M-ITX) might have printed some stray debug number,
and don't have the inital text position at the beginning of the line:
carriage return, and shorten the message while at it.

--- grub-2.06/grub-core/kern/main.c.orig	2023-11-24 11:25:02.293274479 +0100
+++ grub-2.06/grub-core/kern/main.c	2023-11-24 11:25:32.125275949 +0100
@@ -272,7 +272,7 @@
 
   /* Hello.  */
   grub_setcolorstate (GRUB_TERM_COLOR_HIGHLIGHT);
-  grub_printf ("Welcome to GRUB!\n\n");
+  grub_printf ("\rGRUB\n");
   grub_setcolorstate (GRUB_TERM_COLOR_STANDARD);
 
   /* Init verifiers API. */
