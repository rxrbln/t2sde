if pkgcheck lilo X
then
	menu_begin MENU_PKG_LILO 'LILO Options'
	bool 'Do not write to disk while booting' SDECFG_PKG_LILO_READONLY 0
	text 'Support for extra large floppies' SDECFG_PKG_LILO_XL_SECS ""
	menu_end
fi
