--- grub-0.97/netboot/ntulip.c.vanilla	2008-08-20 13:35:49.000000000 +0200
+++ grub-0.97/netboot/ntulip.c	2008-08-20 13:36:23.000000000 +0200
@@ -857,10 +857,8 @@
