--- grub-0.97/stage2/Makefile.am.vanilla	2021-05-09 17:18:52.943421272 +0200
+++ grub-0.97/stage2/Makefile.am	2021-05-09 17:19:18.179420266 +0200
@@ -278,4 +278,4 @@
 # General rule for making a raw binary.
 SUFFIXES = .exec
