@@ -544,5 +544,12 @@
         }
 
+      /* If we count-down a timeout, poll for key, to avoid excessive redraw */
+      if (grub_timeout >= 0) {
+        /* wait for key or timeout change */
+	while (checkkey () < 0 && (time1 = getrtsecs()) == time2 && time1 != 0xFF)
+	  ;
+	/* fall thru on keypress or clock tick */
+      }
 
