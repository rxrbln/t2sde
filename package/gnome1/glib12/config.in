if pkgcheck glib12 X
then
	menu_begin MENU_PKG_GNOME14 'GNOME 1.4 Package Options'
		text 'Install prefix for GNOME  1.4 Packages' \
			SDECFG_PKG_GNOME14_CORE_PREFIX "opt/gnome"
	menu_end
fi
