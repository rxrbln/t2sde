if pkgcheck xboard X; then
      menu_begin MENU_PKG_GAMES_XBOARD 'XBoard'
	bool 'prefer Xaw3d' SDECFG_PKG_XBOARD_XAW3D 1 "
	  use Xaw3d instead of Xaw"
	bool 'enable XPM' SDECFG_PKG_XBOARD_XPM 1 "
	  use libXpm if found"
	bool 'use ptys' SDECFG_PKG_XBOARD_PTYS 1 "
	  use of pseudo-ttys instead of pipes with child processes"
	bool 'enable ICS interface' SDECFG_PKG_XBOARD_ZIPPY 0 "
	  enable features for interfacing a chess program to ICS"
	bool 'use SIGINT' SDECFG_PKG_XBOARD_SIGINT 1 "
	  sending SIGINT (^C) wakes up GNU Chess instead of typing a command wakes up GNU Chess"
      menu_end
fi
