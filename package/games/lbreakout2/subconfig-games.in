if pkgcheck lbreakout2 X; then
      menu_begin MENU_PKG_GAMES_LBREAKOUT2 'LBreakout 2'
	bool 'sound support' SDECFG_PKG_LBREAKOUT2_SOUND 1 "
	  Sound support"
	bool 'network support' SDECFG_PKG_LBREAKOUT2_NET 1 "
	  Network support"
      menu_end
fi
