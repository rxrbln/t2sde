if pkgcheck xskat X; then
      menu_begin MENU_PKG_GAMES_XSKAT 'XSkat'
	text 'default IRC server' SDECFG_PKG_XSKAT_IRCSERV 'irc.fu-berlin.de' "
	  the default IRC server for network games"
      menu_end
fi
