if pkgcheck flightgear X; then
      menu_begin MENU_PKG_GAMES_FLIGHTGEAR 'FlightGear'
	bool 'multi-pilot networking' SDECFG_PKG_FLIGHTGEAR_OLK 0 "
	  Include Oliver's multi-pilot networking support"
	bool 'Use WeatherCM' SDECFG_PKG_FLIGHTGEAR_WEATHERCM 0 "
	  Use WeatherCM instead of FGEnvironment"
	bool 'tile loading threads' SDECFG_PKG_FLIGHTGEAR_THREADS 0 "
	  Include tile loading threads"
      menu_end
fi
