if pkgcheck gltron X; then
      menu_begin MENU_PKG_GAMES_GLTRON 'GL Tron'
	bool 'local data directory' SDECFG_PKG_GLTRON_LOCALDIR 0 "
	  Use local data directory"
	bool 'sound support' SDECFG_PKG_GLTRON_SOUND 1 "
	  Compile in sound"
	bool 'network support (experimental)' SDECFG_PKG_GLTRON_NET 0 "
	  Experimental network mode"
      menu_end
fi
