if pkgcheck crimson X; then
      menu_begin MENU_PKG_GAMES_CRIMSON 'Crimson Battlefields'
	bool 'compress data files' SDECFG_PKG_CRIMSON_ZLIB 1 "
	  whether datafiles should be compressed using zlib"
	bool 'sound support' SDECFG_PKG_CRIMSON_SOUND 1 "
	  whether sound should be supported"
	bool 'level compiler' SDECFG_PKG_CRIMSON_CFED 1 "
	  build and install the level compiler"
	bool 'BattleIsle map converter' SDECFG_PKG_CRIMSON_BI2CF 1 "
	  build and install the BattleIsle map converter"
	bool 'graphical level editor' SDECFG_PKG_CRIMSON_COMET 1 "
	  build and install the graphical level editor"
      menu_end
fi
