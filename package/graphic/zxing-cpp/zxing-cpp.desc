[I] An multi-format linear/matrix barcode image processing library

[T] ZXing-C++ ("zebra crossing") is an open-source, multi-format
[T] linear/matrix barcode image processing library implemented in C++.

[U] https://github.com/zxing-cpp/zxing-cpp

[A] Axel from Berlin
[A] ZXing authors
[M] René Rebe <rene@exactco.de>

[C] extra/multimedia
[F] CROSS

[L] APL
[V] 3.1.0
[P] X -----5---9 133.900

[D] b6ee5507ae7d31036497c048dbb2cda3c32e5735510fb4f43d3fd0b8 zxing-cpp-3.1.0.tar.gz https://github.com/zxing-cpp/zxing-cpp/archive/v3.1.0/

var_append cmakeopt ' ' -DZXING_USE_BUNDLED_ZINT=OFF
var_append cmakeopt ' ' "-DZXING_EXAMPLES=OFF -DZXING_WRITERS=BOTH"

inst() {
	cd $builddir/zxing-cpp*/
	rm -rf core/src/libzint
	rm -f core/src/*.cpp
	rm -f core/src/*/*.{c,cpp,md}
	mv core/src core/ZXing
	cp -rv core/ZXing $root$includedir/
}
hook_add postmake 5 inst
