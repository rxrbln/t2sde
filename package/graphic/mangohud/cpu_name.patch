+void HudElements::cpu_name() {
+       if (HUDElements.params->enabled[OVERLAY_PARAM_ENABLED_cpu_name]
+               && !HUDElements.sw_stats->cpuName.empty()) {
+               ImguiNextColumnFirstItem();
+               ImGui::PushFont(HUDElements.sw_stats->font_secondary);
+               HUDElements.TextColored(HUDElements.colors.engine, "%s", HUDElements.sw_stats->cpuName.c_str());
+               ImGui::PopFont();
+       }
+}
