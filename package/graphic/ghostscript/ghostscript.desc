var_append makeopt ' ' so
var_append makeinstopt ' ' 'soinstall -j1'

[[ $arch = arm* && "$SDECFG_DEFAULT_CC" = clang ]] && var_append GCC_WRAPPER_REMOVE ' ' -mfpu=neon
