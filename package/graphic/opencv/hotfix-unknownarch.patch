--- opencv-5.0.0/3rdparty/mlas/CMakeLists.txt.vanilla	2026-07-02 14:09:52.342649761 +0200
+++ opencv-5.0.0/3rdparty/mlas/CMakeLists.txt	2026-07-02 14:10:15.041738277 +0200
@@ -61,6 +61,16 @@
   set(MLAS_S390X TRUE CACHE INTERNAL "" FORCE)
 endif()
 
+if(NOT (MLAS_WASM OR MLAS_ARM64 OR MLAS_ARM OR MLAS_POWER OR MLAS_X86 OR
+        MLAS_X86_64 OR MLAS_RISCV64 OR MLAS_LOONGARCH64 OR MLAS_S390X))
+  set(OPENCV_DNN_MLAS_SKIP_REASON
+    "unsupported architecture ${CMAKE_SYSTEM_PROCESSOR}"
+    CACHE INTERNAL "" FORCE)
+  message(STATUS "MLAS: no kernels for ${CMAKE_SYSTEM_PROCESSOR}; "
+                 "MLAS disabled (DNN will use its built-in SGEMM)")
+  return()
+endif()
+
 set(mlas_platform_srcs)
 
