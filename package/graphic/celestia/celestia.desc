pkginstalled freeglut && var_append confopt ' ' --with-glut
pkginstalled qt3 && var_append confopt ' ' --with-kde
pkginstalled libadwaita && var_append confopt ' ' --with-gnome
pkginstalled gtk+ && var_append confopt ' ' --with-gtk
