[I] QR Code generator C++ library

[T] qrcodegencpp is the C++ implementation of Project Nayuki's QR Code
[T] generator library.

[U] https://www.nayuki.io/page/qr-code-generator-library

[A] Project Nayuki
[M] kei <keletrh@gmail.com>

[C] extra/graphic
[F] CROSS FPIC

[L] MIT
[V] 1.8.0
[P] X -----5---9 400.000

[D] b5346805d2be5d0ad222cfdeaceb17cacff73c3c5e5de93d7e6af54a qrcodegencpp-1.8.0.tar.gz https://github.com/nayuki/QR-Code-generator/archive/refs/tags/v1.8.0/

srcdir=QR-Code-generator*/cpp

var_append makeopt ' ' libqrcodegencpp.a
makeinstopt=

qrcodegencpp_install() {
	install -Dm644 libqrcodegencpp.a $root$libdir/libqrcodegencpp.a
	install -Dm644 qrcodegen.hpp $root$includedir/qrcodegencpp/qrcodegen.hpp
	install -dm755 $root$libdir/pkgconfig
	cat <<-EOT > $root$libdir/pkgconfig/qrcodegencpp.pc
	prefix=/$prefix
	exec_prefix=\${prefix}
	libdir=\${prefix}/${libdir##*/}
	includedir=\${prefix}/include/qrcodegencpp

	Name: qrcodegencpp
	Description: QR Code generator C++ library
	Version: $desc_V
	Libs: -L\${libdir} -lqrcodegencpp
	Cflags: -I\${includedir}
EOT
}
hook_add postmake 5 qrcodegencpp_install
