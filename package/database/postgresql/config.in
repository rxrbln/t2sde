if pkgcheck postgresql X
then
	menu_begin MENU_PKG_POSTGRESQL 'Postgresql Package Options'
		text 'Install prefix for Postgresql Packages' \
			SDECFG_PKG_POSTGRESQL_CORE_PREFIX "opt/postgresql"
	menu_end
fi
