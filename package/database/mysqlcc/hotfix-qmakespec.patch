--- ./configure.in.orig	2003-12-13 20:10:43.000000000 -0300
+++ ./configure.in	2005-02-12 11:37:12.733286108 -0300
@@ -25,7 +25,7 @@
 AC_SUBST(MYSQLCC_SOURCES)
 AC_OUTPUT(mysqlcc.pro)
 if test -z "${QMAKESPEC}"; then
