Tiny lil typo that caused and hour of configure script debugging...
	--jsaw

--- db-3.3.11/dist/configure	2001-07-13 03:34:11.000000000 +0200
+++ db-3.3.11-t2/dist/configure	2006-01-05 16:48:11.000000000 +0100
@@ -8728,7 +8728,7 @@
 	done
 	JTOPDIR=`echo "$JAVACABS" | sed -e 's://*:/:g' -e 's:/[^/]*$::'`
 	case "$host_os" in
-		darwin*)	JTOPDIR=`echo "$JTOPDIR" | sed -e s:/[^/]*$::'`
+		darwin*)	JTOPDIR=`echo "$JTOPDIR" | sed -e 's:/[^/]*$::'`
 				JNIHEADERDIR="$JTOPDIR/Headers";;
 		*)		JNIHEADERDIR="$JTOPDIR/include";;
 	esac

