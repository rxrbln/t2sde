+{
+	b43_phy_ac_classifier(dev, B43_PHY_AC_CLASSCTL_CCKEN |
+				   B43_PHY_AC_CLASSCTL_OFDMEN |
+				   B43_PHY_AC_CLASSCTL_WAITEDEN,
+			      B43_PHY_AC_CLASSCTL_CCKEN |
+				   B43_PHY_AC_CLASSCTL_OFDMEN |
+				   B43_PHY_AC_CLASSCTL_WAITEDEN);
