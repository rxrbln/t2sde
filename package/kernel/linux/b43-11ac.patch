+ * vs external-PA choice comes from the board (SROM extpagain); until the
+ * SROM11 parsing is ported the caller passes it in. wl: the table_write of
+ * id 0x20 at the tail of the txgain selector.
+ */
+void b43_phy_ac_upload_tx_gain_table(struct b43_wldev *dev, bool ghz5, bool ipa)
+{
+	const u16 *table;
+
+	if (ipa)
+		table = ghz5 ? b43_acphy_txgain_ipa_5g_2069rev0
+			     : b43_acphy_txgain_ipa_2g_2069rev0;
+	else
+		table = ghz5 ? b43_acphy_txgain_epa_5g_2069rev0
+			     : b43_acphy_txgain_epa_2g_2069rev0;
+
+	b43_phy_ac_table_write_bulk(dev, B43_PHY_AC_TBL_TXGAIN, 0, 48, 128,
+				    table);
+}
