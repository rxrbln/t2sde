+/**************************************************
+ * Initialisation table loader
+ **************************************************/
+
+/* Mirrors wl's per-PHY-rev table init loop: replay every descriptor in order.
+ * Only the rev0 set (BCM4360 / radio 2069) is ported so far.
+ */
+void b43_phy_ac_tables_init(struct b43_wldev *dev)
+{
+	const struct b43_phy_ac_tbl *t;
+	unsigned int i;
+
+	for (i = 0; i < ARRAY_SIZE(b43_phy_ac_tbls_rev0); i++) {
+		t = &b43_phy_ac_tbls_rev0[i];
+		b43_phy_ac_table_write_bulk(dev, t->id, t->offset, t->width,
+					    t->count, t->data);
+	}
+}
