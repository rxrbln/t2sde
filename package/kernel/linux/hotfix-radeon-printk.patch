--- linux-7.0/drivers/gpu/drm/radeon/radeon_display.c.vanilla	2026-04-13 16:02:46.556194903 +0200
+++ linux-7.0/drivers/gpu/drm/radeon/radeon_display.c	2026-04-13 16:03:50.053396227 +0200
@@ -776,8 +776,7 @@
 	drm_info(dev, "Radeon Display Connectors\n");
 	list_for_each_entry(connector, &dev->mode_config.connector_list, head) {
 		radeon_connector = to_radeon_connector(connector);
-		drm_info(dev, "Connector %d:\n", i);
-		drm_info(dev, "  %s\n", connector->name);
+		drm_info(dev, "Connector %d: %s\n", i, connector->name);
 		if (radeon_connector->hpd.hpd != RADEON_HPD_NONE)
 			drm_info(dev, "  %s\n", hpd_names[radeon_connector->hpd.hpd]);
 		if (radeon_connector->ddc_bus) {
--- linux-6.11/drivers/gpu/drm/radeon/radeon_fbdev.c.vanilla	2024-10-12 12:04:48.241677883 +0200
