+static int cvt_ascii_address(struct net_device *dev, char *s)
+{
+    u8 mac[ETH_ALEN];
+    int i, j, da, c;
+
+    if (strlen(s) != 12)
+	return -1;
+    for (i = 0; i < 6; i++) {
+	da = 0;
+	for (j = 0; j < 2; j++) {
+	    c = *s++;
+	    da <<= 4;
+	    da += ((c >= '0') && (c <= '9')) ?
+		(c - '0') : ((c & 0x0f) + 9);
+	}
+	mac[i] = da;
+    }
+    eth_hw_addr_set(dev, mac);
+    return 0;
+}
