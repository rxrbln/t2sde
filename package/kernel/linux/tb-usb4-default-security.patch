Default to no security, so thunderbolt devices just work, even in a minimal install
or install environment.

TODO: add sysfs interface to change secuirty level after boot.

Signed-off-by: René Rebe <rene@exactco.de>

--- linux-7.1/drivers/thunderbolt/tb.c.orig	2026-06-14 16:58:38.000000000 +0200
+++ linux-7.1/drivers/thunderbolt/tb.c	2026-07-15 12:27:04.372396383 +0200
@@ -1421,6 +1421,20 @@
 	tb_add_dp_resources(sw);
 	tb_scan_switch(sw);
 
+	/*
+	 * Only auto-approve (and thus create PCIe tunnels) for hotplugged
+	 * switches. During boot discovery the domain is scanned before
+	 * tb_discover_tunnels() runs, so approving here would build a new
+	 * PCIe tunnel that conflicts with the one the boot firmware already
+	 * set up and make its discovery fail ("failed to discover path
+	 * starting at HopID 8"). Boot-firmware tunneled switches are marked
+	 * authorized later in tb_scan_finalize_switch() instead.
+	 */
+	if (tcm->hotplug_active &&
+	    sw->tb->security_level == TB_SECURITY_NONE &&
+	    !tb_domain_approve_switch(sw->tb, sw))
+		sw->authorized = 1;
+
 out_rpm_put:
 	if (port->usb4) {
 		pm_runtime_mark_last_busy(&port->usb4->dev);
@@ -3373,7 +3387,7 @@
 		return NULL;
 
 	if (tb_acpi_may_tunnel_pcie())
-		tb->security_level = TB_SECURITY_USER;
+		tb->security_level = TB_SECURITY_NONE;
 	else
 		tb->security_level = TB_SECURITY_NOPCIE;
 
