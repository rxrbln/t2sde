CC is set during cross compilation and utilzing non default compilers (ICC et al).

  - Rene Rebe <rene@exactcode.de>

--- ncurses-5.7/c++/Makefile.in.vanilla	2008-11-04 08:51:36.000000000 +0100
+++ ncurses-5.7/c++/Makefile.in	2008-11-04 08:52:11.000000000 +0100
@@ -75,7 +75,7 @@
 INCDIR		= ../include
 CPPFLAGS	= -I../c++ -I$(INCDIR) -I$(srcdir) -DHAVE_CONFIG_H @CPPFLAGS@
 
-CC		= ${CXX}
+override CC		= ${CXX}
 CCFLAGS		= $(CPPFLAGS) $(CXXFLAGS)
 
 CFLAGS_LIBTOOL	= $(CCFLAGS)
