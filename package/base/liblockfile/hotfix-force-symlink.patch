--- liblockfile/Makefile.in.vanilla	2019-10-25 20:52:54.907963111 +0000
+++ liblockfile/Makefile.in	2019-10-25 20:53:06.323962921 +0000
@@ -56,8 +56,8 @@
 		install -d -m 755 -g root -p $(libdir)
 		install -m 755 liblockfile.so \
 			$(libdir)/liblockfile.so.$(SOVER)
-		ln -s liblockfile.so.$(SOVER) $(libdir)/liblockfile.so.$(MAJOR)
-		ln -s liblockfile.so.$(SOVER) $(libdir)/liblockfile.so
+		ln -sf liblockfile.so.$(SOVER) $(libdir)/liblockfile.so.$(MAJOR)
+		ln -sf liblockfile.so.$(SOVER) $(libdir)/liblockfile.so
 		if test "$(DESTDIR)" = ""; then @LDCONFIG@; fi
 
 install_common:
