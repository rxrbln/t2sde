if pkgcheck busybox X
then
	menu_begin MENU_PKG_BUSYBOX 'Busybox Package Options'
		bool 'Create Busybox Emergency (static) toolkit' \
						SDECFG_PKG_BUSYBOX_ET 0
		if [ "$SDECFG_PKG_BUSYBOX_ET" = 1 ]; then
			block_begin 5
			text 'Emergency toolkit directory' \
				SDECFG_PKG_BUSYBOX_ET_DIR '/emergency'
			block_end
		fi
		bool 'Create Busybox symlinks' SDECFG_PKG_BUSYBOX_SYMLINKS 0
	menu_end
fi
