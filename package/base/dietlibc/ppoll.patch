For udev, too.

  - Rene Rebe <rene@exactcode.de>

--- /dev/null	2010-10-27 14:43:31.488782000 +0200
+++ dietlibc/syscalls.s/__ppoll.S	2011-01-05 15:37:28.000000000 +0100
@@ -0,0 +1,3 @@
+#include "syscalls.h"
+
+syscall(ppoll,__ppoll)
--- /dev/null   2010-10-27 14:43:31.488782000 +0200
+++ dietlibc/lib/ppoll.c     2010-11-13 12:54:09.000000000 +0100
@@ -0,0 +1,11 @@
+#include <sys/types.h>
+#include <fcntl.h>
+#define _GNU_SOURCE
+#include <poll.h>
+
+int __ppoll(struct pollfd *fds, nfds_t nfds, const struct timespec *timeout, const sigset_t *sigmask, long sigsetsize);
+int __libc_ppoll(struct pollfd *fds, nfds_t nfds, const struct timespec *timeout, const sigset_t *sigmask) {
+  return __ppoll(fds, nfds, timeout, sigmask, _NSIG/8);
+}
+int ppoll(struct pollfd *fds, nfds_t nfds, const struct timespec *timeout, const sigset_t *sigmask)
+__attribute__((weak,alias("__libc_ppoll")));
