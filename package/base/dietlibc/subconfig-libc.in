if pkgcheck dietlibc X
then
	comment 'Dietlibc Options'
	bool 'Link binaries dynamically with dietlibc' SDECFG_DIETLIBC_DYN 0
	bool 'WANT_SYSENTER' SDECFG_DIETWANT_SYSENTER 1

	if [ $SDECFG_LIBC != dietlibc ]; then
		block_begin 2
		pkgout
		for i in `grep " DIETLIBC " config/$config/packages |
				cut -f5 -d" " | sort`
		do
			x="${i//[+.-]/_}"
			bool "Build package with dietlibc: $i" \
			     "SDECFG_DIETLIBC_${x}" 0
		done
		block_end
	fi
	comment ' '
fi
