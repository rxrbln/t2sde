WARNING: ugly workaround to prevent linkage with libgcc_s in toolchain stage
Stage 5: /bin/bash: can't resolve symbol '__moddi3' in lib '/bin/bash'.

--- ./libc/stdlib/lldiv.c.orig	2005-08-18 00:49:41.000000000 +0200
+++ ./libc/stdlib/lldiv.c	2005-12-21 23:49:13.000000000 +0100
@@ -28,8 +28,8 @@
 {
     lldiv_t result;
 
-    result.quot = numer / denom;
-    result.rem = numer % denom;
+    result.quot = (long int) numer / (long int) denom;
+    result.rem = (long int) numer % (long int ) denom;
 
     /* The ANSI standard says that |QUOT| <= |NUMER / DENOM|, where
        NUMER / DENOM is to be computed in infinite precision.  In
