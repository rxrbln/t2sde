if [ "$SDECFG_LIBC" = "musl" ]; then
    if [ "$SDECFG_X8664_X32" = 1 ]; then
	const SDECFG_MULTILIBLIST "mx32"
	SDECFGSET_MULTILIBLIST="mx32"
    else
	SDECFGSET_MULTILIB=0
	const SDECFG_MULTILIBLIST ""
	SDECFGSET_MULTILIBLIST=""
    fi
fi
