--- libsafe-2.0-16/src/Makefile.vanilla	2007-08-17 14:40:04.000000000 +0200
+++ libsafe-2.0-16/src/Makefile	2007-08-17 14:42:27.000000000 +0200
@@ -118,8 +118,7 @@
 		 rm -f $(PRELOAD) ;\
 		fi; \
 
-		$(INSTALL) $(LIBNAME) $(LIBDIR) 
-		/sbin/ldconfig
+		$(INSTALL) $(LIBNAME) $(DESTDIR)$(LIBDIR) 
 
 		 @if [ -s $(PRELOAD).tmp ] ; then \
 		  cp -fp $(PRELOAD).tmp $(PRELOAD);\
@@ -136,12 +135,12 @@
 
 # If you have man pages in some other directory  add it here.
 
-		@if [  -d $(MANDIR) ];  then \
-		 echo "$(INSTALL) $(MANNAME) $(MANDIR)"; \
-		 $(INSTALL) $(MANNAME) $(MANDIR); \
-		elif [  -d /usr/share/man/man8 ];  then \
-		  echo "$(INSTALL) $(MANNAME) /usr/share/man/man8"; \
-		  $(INSTALL) $(MANNAME) /usr/share/man/man8; \
+		@if [  -d $(DESTDIR)$(MANDIR) ];  then \
+		 echo "$(INSTALL) $(MANNAME) $(DESTDIR)$(MANDIR)"; \
+		 $(INSTALL) $(MANNAME) $(DESTDIR)$(MANDIR); \
+		elif [  -d $(DESTDIR)/usr/share/man/man8 ];  then \
+		  echo "$(INSTALL) $(MANNAME) $(DESTDIR)/usr/share/man/man8"; \
+		  $(INSTALL) $(MANNAME) $(DESTDIR)/usr/share/man/man8; \
 		else echo "***** Error: Cannot find man directories"; \
 		fi
 
