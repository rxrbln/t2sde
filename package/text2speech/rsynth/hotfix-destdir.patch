--- rsynth-2.0/Makefile.in.vanilla	2007-06-18 11:56:04.801457324 +0200
+++ rsynth-2.0/Makefile.in	2007-06-18 11:56:27.994779036 +0200
@@ -65,11 +65,11 @@
 
 install  : $(PROGS) $(DICTS)
 	for f in $(PROGS); do \
-	$(INSTALL_PROG) $$f $(BIN_DIR); \
+	$(INSTALL_PROG) $$f $(DESTDIR)$(BIN_DIR); \
 	done
-	$(INSTALL) -d $(LIB_DIR)
+	$(INSTALL) -d $(DESTDIR)$(LIB_DIR)
 	for f in $(DICTS); do \
-	$(INSTALL_DATA) $$f $(LIB_DIR); \
+	$(INSTALL_DATA) $$f $(DESTDIR)$(LIB_DIR); \
 	done
 
 @make_dist@
