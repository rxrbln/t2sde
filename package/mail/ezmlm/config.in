if pkgcheck ezmlm X
then
 	menu_begin MENU_PKG_EZMLM 'Ezmlm Package Options'

	comment 'Ezmlm supports 3 ways for storing subscribers:'

	pkgcheck mysql X &&
		sub_choice_mysql="mysql 'Use MySQL for storing subscribers'"

	pkgcheck postgresql X &&
		sub_choice_pgsql="postgresql 'Use PostgreSQL for storing subscriber'"

	choice SDECFG_PKG_EZMLM_SUB filesystem \
		filesystem 'Use standard filesystem for storing subscribers' \
		$sub_choice_mysql \
		$sub_choice_pgsql

	menu_end
fi
