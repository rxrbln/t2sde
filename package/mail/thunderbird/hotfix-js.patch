 parse._handleContentLine = function(line, state) {
+
+  //icu4c format removal	
+  line = line.replace(/\[\d{4}[a-z]\]$/, "");
+
+if (!line.includes(":") && !line.includes(";")) {
+  // Try to turn raw timezone strings into TZID format
+  if (/^[A-Za-z/_-]+$/.test(line)) {
+    line = "TZID:" + line;
+  } else {
+    console.warn("Dropping invalid line:", line);
+    return;
+  }
