if pkgcheck dbmail X
then
	menu_begin MENU_PKG_DBMAIL 'DBMail Package Options'
		for dbpkg in mysql postgresql sqlite; do
			if pkgcheck $dbpkg X; then
				var_append dblist ' ' $dbpkg
				var_append dblist ' ' "${dbpkg}_as_DB_backend"
			fi
		done
		choice SDECFG_PKG_DBMAIL_DB ${dblist%% *} $dblist
		unset dbpkg dblist
	menu_end
fi
