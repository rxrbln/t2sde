[D] 8bedce0e287dd7f2f2455ef5b042a01ab0d917f98ffcdc85f25b6421 plasma-pa-6.7.1.tar.xz https://download.kde.org/stable/plasma/6.7.1/

. $base/package/*/*/kde-conf.in

atstage cross && var_append CXX_WRAPPER_APPEND ' ' "-L$root$(pkgprefix libdir glib)"
var_append GCC_WRAPPER_APPEND ' ' "$(pkg-config --cflags libcanberra)"

pkginstalled kdoctools docbook-xml docbook-xsl || var_append cmakeopt ' ' -DBUILD_DOC=OFF
