[I] Plasma workspace

[T] Plasma Workspace is used as the base for Plasma Desktop, Mobile, and
[T] Bigscreen. It contains shared KCMs, applets as well as multiple libraries.

[U] https://invent.kde.org/plasma/plasma-workspace

[A] The KDE-Team
[M] René Rebe <rene@exactco.de>

[C] extra/office extra/desktop/kde
[F] CROSS OBJDIR

[E] opt systemd
[E] opt libqualculate
[E] opt xdotool

[L] GPL
[V] 6.6.90
[P] X -----5---9 200.310

[CV-GROUP] kde-plasma
[D] ca5e46d5091ccb3a1e7ca5143b5b9a3a75e1ee083879630e318e41a7 plasma-workspace-6.6.90.tar.xz https://download.kde.org/unstable/plasma/6.6.90/

. $base/package/*/*/kde-conf.in

plasma_splash() {
    gzip -9 < $base/misc/artwork/t2.svg > \
	lookandfeel/org.kde.breeze/contents/splash/images/plasma.svgz
}
hook_add preconf 1 plasma_splash

atstage cross && var_append CXX_WRAPPER_APPEND ' ' "-L$root$(pkgprefix libdir glib)"
pkginstalled kdoctools docbook-xml docbook-xsl || var_append cmakeopt ' ' -DBUILD_DOC=OFF
