--- kinfocenter-6.6.3/kcms/about-distro/src/ArchEntry.cpp.vanilla	2026-03-17 18:57:47.722934699 +0100
+++ kinfocenter-6.6.3/kcms/about-distro/src/ArchEntry.cpp	2026-03-17 19:11:07.489117106 +0100
@@ -0,0 +1,27 @@
+/*
+    SPDX-FileCopyrightText: 2026 René Rebe <rene@t2linux.com>
+    SPDX-License-Identifier: GPL-2.0-only OR GPL-3.0-only OR LicenseRef-KDE-Accepted-GPL
+*/
+
+#include "ArchEntry.h"
+#include "FancyString.h"
+
+#include <sys/utsname.h>
+
+ArchEntry::ArchEntry()
+    : Entry(KLocalizedString(), QString())
+{
+    m_label = ki18n("Architecture:");
+}
+
+QString ArchEntry::localizedValue(Language language) const
+{
+    struct utsname buf;
+ 
+    if (uname(&buf) != 0) {
+        const KLocalizedString l10nUnknown = ki18nc("unknown CPU arch", "unknown");
+        const QString unknownName = localize(l10nUnknown, language);
+    }
+
+    return QString::fromLocal8Bit(buf.machine);
+}
