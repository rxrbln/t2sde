[I] AMD Compute Language Runtime

[T] AMD CLR (Compute Language Runtime) contains source codes for AMD's compute
[T] languages runtimes: HIP and OpenCL™. - hipamd - contains implementation
[T] of HIP language on AMD platform.

[U] https://github.com/ROCm/clr

[A] Advanced Micro Devices, Inc.
[M] René Rebe <rene@exactco.de>

[F] CROSS
[C] extra/development

[E] add cppheaderparser
[E] add hipcc
[E] opt doxygen

[L] MIT
[V] 7.2.4
[P] X -----5---9 300.188

[CV-GROUP] rocm
[D] 079b8e360108be3e739c55e925ef454d58e9f2c8e4131990814f484a clr-rocm-7.2.4.tar.gz https://github.com/ROCm/clr/archive/rocm-7.2.4/
[D] f3aa8a5008ce836d2c8ee39adf36c57afaa4fe039fa82bfc925447c4 HIP-rocm-7.2.4.tar.gz https://github.com/ROCm/HIP/archive/rocm-7.2.4/
[D] 8bd77ea43cc5579be9dace07d7f974d4749a2bdcd7c969dec372931f hipother-rocm-7.2.4.tar.gz https://github.com/ROCm/hipother/archive/rocm-7.2.4/
[D] f539baf40c81ed62fdcaa2252a3dac2c6f9e4fc967e01a22cdf09aed hip-tests-rocm-7.2.4.tar.gz https://github.com/ROCm/hip-tests/archive/rocm-7.2.4/

. $base/package/*/*/rocm-conf.in

var_append cmakeopt ' ' "-DCMAKE_INSTALL_LIBDIR=${libdir##*/}"

extract_hip() {
        tar $taropt `match_source_file -p HIP`
        var_append cmakeopt ' ' "-DHIP_COMMON_DIR=$(echo $PWD/hip-*)"
}
hook_add prepatch 5 extract_hip

var_append cmakeopt ' ' "-DCLR_BUILD_HIP=ON -DCLR_BUILD_OCL=OFF"
[ "$SDECFG_STATIC" = 1 ] || var_append cmakeopt ' ' -DBUILD_SHARED_LIBS=YES
var_append cmakeopt ' ' "-DHIP_COMPILER=clang -DHIP_PLATFORM=amd"
var_append cmakeopt ' ' "-DCMAKE_HIP_ARCHITECTURES=OFF -DHIP_CATCH_TEST=1"
