diff -ur docbook-utils-0.6.14/doc/HTML/Makefile.in docbook-utils-0.6.14-t2/doc/HTML/Makefile.in
--- docbook-utils-0.6.14/doc/HTML/Makefile.in	2004-02-11 15:16:07.000000000 +0100
+++ docbook-utils-0.6.14-t2/doc/HTML/Makefile.in	2006-01-30 04:17:40.000000000 +0100
@@ -299,7 +299,7 @@
 		$(top_srcdir)/doc/refentry/sgmldiff.sgml
