[I] Tools for maintaining centralized SGML catalogs

[T] Tools for maintaining centralized SGML catalogs.

[U] https://docbook.org/

[A] DocBook
[M] andrei32

[C] extra/development

[L] GPL
[V] 0.6.3

[D] 4aca45d4d1c1056a004e566eff41844bcf7be5039ef6cc16e31fd76c sgml-common-0.6.3.tgz https://www.sourceware.org/pub/docbook-tools/new-trials/SOURCES/

var_append makeinstopt ' ' docdir=/usr/share/doc

hook_add preconf 5 "autoreconf -vfi"

catalog() {
	install-catalog --add /etc/sgml/sgml-ent.cat \
		/usr/share/sgml/sgml-iso-entities-8879.1986/catalog

	install-catalog --add /etc/sgml/sgml-docbook.cat \
		/etc/sgml/sgml-ent.cat
}
hook_add finalize 5 catalog
