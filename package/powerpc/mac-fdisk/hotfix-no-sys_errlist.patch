--- mac-fdisk-0.1.orig/errors.c.vanilla	2020-10-28 16:14:27.886528904 +0100
+++ mac-fdisk-0.1.orig/errors.c	2020-10-28 16:15:59.270527821 +0100
@@ -115,11 +115,7 @@
     va_end(ap);
 
 #ifdef __linux__
-    if (value > 0 && value < sys_nerr) {
-	fprintf(stderr, "  (%s)\n", sys_errlist[value]);
-    } else {
-	fprintf(stderr, "\n");
-    }
+    fprintf(stderr, "  (%s)\n", strerror(value));
 #else
     fprintf(stderr, "\n");
 #endif
@@ -144,11 +140,7 @@
     va_end(ap);
 
 #ifdef __linux__
-    if (value > 0 && value < sys_nerr) {
-	fprintf(stderr, "  (%s)\n", sys_errlist[value]);
-    } else {
-	fprintf(stderr, "\n");
-    }
+    fprintf(stderr, "  (%s)\n", strerror(value));
 #else
     fprintf(stderr, "\n");
 #endif
