[I] A general-purpose full virtualizer for x86 hardware

[T] InnoTek VirtualBox is a general-purpose full virtualizer for x86 hardware.
[T] Targeted at server, desktop and embedded use, it is a professional-quality
[T] virtualization solution that is now also Open Source Software.

[U] https://www.virtualbox.org/

[A] InnoTek
[A] Sun Microsystems
[M] René Rebe <rene@exactco.de>

[C] extra/emulator

[F] NO-LTO NO-PIE NO-SSP
[R] + arm64 x86-64

[L] GPL
[V] 7.2.14

[CV-URL] http://www.virtualbox.org/wiki/Downloads
[D] bb0019efd0714ca3b6cd7e3098b6fceec2b25ce1ae37b7b787377fee VirtualBox-7.2.14.tar.bz2 http://download.virtualbox.org/virtualbox/7.2.14/

prefix="opt/VirtualBox"; set_confopt

runmake=0 confopt=
var_append confopt ' ' --disable-kmods
var_append confopt ' ' --disable-hardening
var_append confopt ' ' --disable-java
var_append confopt ' ' --disable-docs # needs java, too?

var_remove GCC_WRAPPER_APPEND ' ' -fPIC
var_append GCC_WRAPPER_APPEND ' ' "-I$root$(pkgprefix includedir libxcb) -L$root$(pkgprefix libdir libxcb)"

hook_add inmake 5 "source env.sh; kmk -j$SDECFG_PARALLEL all"

vbox_install() {
	cd out/*/release/bin/
	install VirtualBox $root$bindir/
	install *.so $root$libdir/
}
hook_add postmake 5 vbox_install
