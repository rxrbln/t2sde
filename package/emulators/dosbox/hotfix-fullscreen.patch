Index: src/gui/sdlmain.cpp
===================================================================
--- ./src/gui/sdlmain.cpp	(working copy)
+++ ./src/gui/sdlmain.cpp	(working copy)
@@ -91,6 +91,16 @@ PFNGLUNMAPBUFFERARBPROC glUnmapBufferARB
 
 #endif //C_OPENGL
 
+#if C_XINERAMA && !defined(WIN32) && !defined(MACOSX)
+// On X11/Xinerama multi-monitor setups SDL 1.2 spans fullscreen across the
+// whole virtual desktop unless a specific head is requested. Confine alt-enter
+// fullscreen to the monitor the user is currently on. See end of this file.
+#define C_FULLSCREEN_CURRENT_HEAD 1
+static void SetFullscreenCurrentHead(void);
+#else
+static void SetFullscreenCurrentHead(void) { }
+#endif
+
 #if !(ENVIRON_INCLUDED)
 extern char** environ;
 #endif
@@ -1930,7 +1940,10 @@ int main(int argc, char* argv[]) {
 	 */
 	putenv(const_cast<char*>("SDL_DISABLE_LOCK_KEYS=1"));
 #endif
-	// Don't init timers, GetTicks seems to work fine and they can use a fair amount of power (Macs again) 
+	// Pin fullscreen to the monitor the user is currently on (must run before
+	// SDL_Init, as SDL 1.2 latches the fullscreen head during video init).
+	SetFullscreenCurrentHead();
+	// Don't init timers, GetTicks seems to work fine and they can use a fair amount of power (Macs again)
 	// Please report problems with audio and other things.
 	if ( SDL_Init( SDL_INIT_AUDIO|SDL_INIT_VIDEO | /*SDL_INIT_TIMER |*/ SDL_INIT_CDROM
 		|SDL_INIT_NOPARACHUTE
@@ -2093,3 +2106,55 @@ void GFX_GetSize(int &width, int &height
 	height = sdl.draw.height;
 	fullscreen = sdl.desktop.fullscreen;
 }
+
+#if C_FULLSCREEN_CURRENT_HEAD
+// Kept at the very end of the translation unit so the X11 headers (which define
+// clashing preprocessor macros like KeyPress/Bool) cannot leak into the rest of
+// the DOSBox code above.
+#include <X11/Xlib.h>
+#include <X11/extensions/Xinerama.h>
+
+// SDL 1.2 only confines fullscreen to a single Xinerama head when
+// SDL_VIDEO_FULLSCREEN_HEAD (or _DISPLAY) is set, and it reads that value once,
+// during video initialisation. Without it, alt-enter fullscreen stretches over
+// the whole virtual desktop. Pick the head that currently holds the mouse
+// pointer so fullscreen only covers the monitor the user is working on.
+static void SetFullscreenCurrentHead(void) {
+	// Honour an explicit choice made by the user.
+	if (getenv("SDL_VIDEO_FULLSCREEN_HEAD") || getenv("SDL_VIDEO_FULLSCREEN_DISPLAY"))
+		return;
+
+	Display *dpy = XOpenDisplay(NULL);
+	if (!dpy)
+		return;
+
+	int event_base, error_base;
+	if (XineramaQueryExtension(dpy, &event_base, &error_base) && XineramaIsActive(dpy)) {
+		int screens = 0;
+		XineramaScreenInfo *xi = XineramaQueryScreens(dpy, &screens);
+		if (xi && screens > 1) {
+			int head = xi[0].screen_number;
+			Window root = DefaultRootWindow(dpy);
+			Window root_ret, child_ret;
+			int root_x = 0, root_y = 0, win_x, win_y;
+			unsigned int mask;
+			if (XQueryPointer(dpy, root, &root_ret, &child_ret,
+			                  &root_x, &root_y, &win_x, &win_y, &mask)) {
+				for (int i = 0; i < screens; i++) {
+					if (root_x >= xi[i].x_org && root_x < xi[i].x_org + xi[i].width &&
+					    root_y >= xi[i].y_org && root_y < xi[i].y_org + xi[i].height) {
+						head = xi[i].screen_number;
+						break;
+					}
+				}
+			}
+			char buf[16];
+			snprintf(buf, sizeof(buf), "%d", head);
+			setenv("SDL_VIDEO_FULLSCREEN_HEAD", buf, 1);
+		}
+		if (xi)
+			XFree(xi);
+	}
+	XCloseDisplay(dpy);
+}
+#endif // C_FULLSCREEN_CURRENT_HEAD
