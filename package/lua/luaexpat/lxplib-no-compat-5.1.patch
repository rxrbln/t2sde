--- luaexpat-1.0.1-vanilla/src/lxplib.c	2005-03-28 19:53:22.000000000 +0200
+++ luaexpat-1.0.1/src/lxplib.c	2006-03-13 21:16:55.000000000 +0100
@@ -13,7 +13,6 @@
 
 #include "lua.h"
 #include "lauxlib.h"
-#include "compat-5.1.h"
 
 
 #include "lxplib.h"
@@ -335,7 +334,7 @@
   while (lua_next(L, 1)) {
     lua_pop(L, 1);  /* remove value */
     if (lua_type(L, -1) != LUA_TSTRING ||
-        luaL_findstring(lua_tostring(L, -1), validkeys) < 0)
+        luaL_checkoption(L, -1, NULL, validkeys) < 0)
       luaL_error(L, "invalid key `%s' in callback table", lua_tostring(L, -1));
   }
 }
