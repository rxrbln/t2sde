--- luaexpat-1.0.1-vanilla/makefile	2005-06-06 22:25:23.000000000 +0200
+++ luaexpat-1.0.1/makefile	2006-03-13 18:59:48.000000000 +0100
@@ -1,17 +1,11 @@
 T= lxp
 V= 1.0.1
-CONFIG= ./config
-
-include $(CONFIG)
 
 
 lib: src/$(LIBNAME)
 
-src/$(LIBNAME) : src/lxplib.o $(COMPAT_DIR)/compat-5.1.o
-	$(CC) -o src/$(LIBNAME) $(LIB_OPTION) src/lxplib.o $(COMPAT_DIR)/compat-5.1.o
-
-$(COMPAT_DIR)/compat-5.1.o: $(COMPAT_DIR)/compat-5.1.c
-	$(CC) -c $(CFLAGS) -o $@ $(COMPAT_DIR)/compat-5.1.c
+src/$(LIBNAME) : src/lxplib.o
+	$(CC) -o src/$(LIBNAME) $(LIB_OPTION) src/lxplib.o
 
 install:
 	mkdir -p $(LUA_LIBDIR)
@@ -21,6 +15,6 @@
 	cp src/$T/lom.lua $(LUA_DIR)/$T
 
 clean:
-	rm -f src/$(LIBNAME) src/lxplib.o $(COMPAT_DIR)/compat-5.1.o
+	rm -f src/$(LIBNAME) src/lxplib.o
 
