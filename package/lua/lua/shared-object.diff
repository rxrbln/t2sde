--- lua-5.1.4/src/Makefile.orig	2008-09-24 21:18:45.000000000 +0200
+++ lua-5.1.4/src/Makefile	2008-09-24 21:18:27.000000000 +0200
@@ -50,6 +50,7 @@
 $(LUA_A): $(CORE_O) $(LIB_O)
 	$(AR) $@ $?
 	$(RANLIB) $@
+	$(CC) -shared -o liblua.so $? -ldl
 
