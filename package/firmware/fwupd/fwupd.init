# Desc: Firmware update daemon
# Runlevel: 99
#

main_begin
	block_begin(start, `Starting fwupd daemon')
		D_libexecdir/fwupd/fwupd &
	block_end

	block_begin(stop, `Stopping fwupd daemon')
		check(`killall fwupd')
	block_end
main_end
