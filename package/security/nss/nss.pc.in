prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: NSS
Description: Network Security Services
Version: @NSS_VERSION@
Requires: nspr >= @NSPR_VERSION@
Libs: -L${libdir} -lssl3 -lsmime3 -lnssutil3 -lnss3 -Wl,-R${libdir}
Cflags: -I${includedir}
