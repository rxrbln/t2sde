if [ ! -f $root/etc/doas.conf ]; then
	cat > $root/etc/doas.conf << 'EOF'
# doas configuration - see doas.conf(5)
permit persist :wheel
EOF
	chmod 600 $root/etc/doas.conf
fi

if [ -d $root/etc/pam.d ]; then
	cat > $root/etc/pam.d/doas << 'EOF'
auth		include		system-auth
account		include		system-auth
session		include		system-auth
EOF
fi
