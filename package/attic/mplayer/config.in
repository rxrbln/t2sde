if pkgcheck mplayer X
then
	menu_begin MENU_PKG_MPLAYER 'MPlayer Options'
	bool 'Enable run-time CPU detection' SDECFG_PKG_MPLAYER_RUN_CPUDETECT 1
	bool 'Enable Blinkenlights support' SDECFG_PKG_MPLAYER_BLINKENLIGHTS 0
	menu_end
fi
