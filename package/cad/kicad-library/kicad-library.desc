[I] Kicad libraries

[T] KiCad organizes symbols into symbol libraries, which hold collections
[T] of symbols. Each symbol in a schematic is uniquely identified by a
[T] full name that is composed of a library nickname and a symbol name.
[T] For example, the identifier Audio:AD1853 refers to the AD1853 symbol
[T] in the Audio library.

[U] https://www.kicad.org/

[A] Jean-Pierre Charras
[M] Aleksi Venäläinen <aleksi.venalainen@outlook.com>

[C] extra/cad
[F] NO-LTO

[L] OpenSource
[V] 10.0.2

[CV-GROUP] kicad
[D] 883d2ffaa45c1b1e7a31d6c1d9db894a72757094a49837ad0cbffe91 kicad-footprints-10.0.2.tar.bz2 https://gitlab.com/kicad/libraries/kicad-footprints/-/archive/10.0.2/
[D] 5276a55c0a04ce5eee0ee7631aa607dd39c02f5a16315ca9e24dbd49 kicad-packages3D-10.0.2.tar.bz2 https://gitlab.com/kicad/libraries/kicad-packages3D/-/archive/10.0.2/
[D] d25b7dbaad2074b77b5dee2623762bc1e9ea758a0cad56ff897ab90e kicad-symbols-10.0.2.tar.bz2 https://gitlab.com/kicad/libraries/kicad-symbols/-/archive/10.0.2/
[D] e8bbf8ecd9a47ac3c62f99c86ea01e68b612863d75a896fb9d744a4b kicad-templates-10.0.2.tar.bz2 https://gitlab.com/kicad/libraries/kicad-templates/-/archive/10.0.2/

packages3D() {
	tar -xf $(match_source_file -p kicad-packages3D.*tar.*)
	cd kicad-packages3D-*
	eval cmake -B kicad-library $cmakeopt
	cmake --build kicad-library
	cmake --install kicad-library
	cd ..

}
hook_add postmake 3 packages3D

symbols() {
	tar -xf $(match_source_file -p kicad-symbols.*tar.*)
	cd kicad-symbols-*
	eval cmake -B kicad-library $cmakeopt
	cmake --build kicad-library
	cmake --install kicad-library
	cd ..

}
hook_add postmake 4 symbols

templates() {
	tar -xf $(match_source_file -p kicad-templates.*tar.*)
	cd kicad-templates-*
	eval cmake -B kicad-library $cmakeopt
	cmake --build kicad-library
	cmake --install kicad-library
}
hook_add postmake 5 templates
