[D] 1952682ae23db97f5e4179b6a4f9b5e258466a57115eee8f7a1c49bf kicad-packages3D-10.0.1.tar.bz2 https://gitlab.com/kicad/libraries/kicad-packages3D/-/archive/10.0.1/
