[I] Kicad libraries

[T] KiCad organizes symbols into symbol libraries, which hold collections
[T] of symbols. Each symbol in a schematic is uniquely identified by a
[T] full name that is composed of a library nickname and a symbol name.
[T] For example, the identifier Audio:AD1853 refers to the AD1853 symbol
[T] in the Audio library.

[U] https://www.kicad.org/

[A] Jean-Pierre Charras
[M] Aleksi Venäläinen <aleksi.venalainen@outlook.com>

[C] extra/cad
[F] NO-LTO

[L] OpenSource
[V] 10.0.5

[CV-GROUP] kicad
[D] 4c69242308b7098f993c1901f75bb2bf25aac7cf7f6691ad264debaf kicad-footprints-10.0.5.tar.bz2 https://gitlab.com/kicad/libraries/kicad-footprints/-/archive/10.0.5/
[D] d806464f64a04976c4e44dad9fd71adb434322a3cda4b85d387cd218 kicad-packages3D-10.0.5.tar.bz2 https://gitlab.com/kicad/libraries/kicad-packages3D/-/archive/10.0.5/
[D] 5d39244816ee3387c2accfa0aaa157bb612ee94db2a4ae6d58d6bf54 kicad-symbols-10.0.5.tar.bz2 https://gitlab.com/kicad/libraries/kicad-symbols/-/archive/10.0.5/
[D] 8afbca040591b42eaffde20bed92340931a56602229bff641a676643 kicad-templates-10.0.5.tar.bz2 https://gitlab.com/kicad/libraries/kicad-templates/-/archive/10.0.5/

packages3D() {
	tar -xf $(match_source_file -p kicad-packages3D.*tar.*)
	cd kicad-packages3D-*
	eval cmake -B kicad-library $cmakeopt
	cmake --build kicad-library
	cmake --install kicad-library
	cd ..

}
hook_add postmake 3 packages3D

symbols() {
	tar -xf $(match_source_file -p kicad-symbols.*tar.*)
	cd kicad-symbols-*
	eval cmake -B kicad-library $cmakeopt
	cmake --build kicad-library
	cmake --install kicad-library
	cd ..

}
hook_add postmake 4 symbols

templates() {
	tar -xf $(match_source_file -p kicad-templates.*tar.*)
	cd kicad-templates-*
	eval cmake -B kicad-library $cmakeopt
	cmake --build kicad-library
	cmake --install kicad-library
}
hook_add postmake 5 templates
