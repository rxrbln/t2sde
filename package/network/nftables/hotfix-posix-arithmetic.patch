--- nftables-1.1.6/configure.ac.vanilla	2026-04-12 19:28:00.758064096 +0200
+++ nftables-1.1.6/configure.ac	2026-04-12 19:29:20.621551210 +0200
@@ -157,8 +157,10 @@
 	echo "	${STABLE_RELEASE}"
 	echo "};"
 	echo "static char nftbuildstamp[[]] = {"
-	for ((i = 56; i >= 0; i-= 8)); do
+	i=56
+	while [ "$i" -ge 0 ]; do
 		echo "	((uint64_t)MAKE_STAMP >> $i) & 0xff,"
+		i=$(expr $i - 8)
 	done
 	echo "};"
 ) >nftversion.h
