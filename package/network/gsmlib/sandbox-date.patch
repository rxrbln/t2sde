--- gsmlib-1.10/doc/Makefile.in.vanilla	2006-08-21 12:10:59.000000000 +0000
+++ gsmlib-1.10/doc/Makefile.in	2006-08-21 12:11:16.000000000 +0000
@@ -394,15 +394,15 @@
 
 
 %.1: %.man
-		sed -e "s/##VERSION##/$(VERSION)/g;s/##DATE##/`date`/g" \
+		sed -e "s/##VERSION##/$(VERSION)/g;s/##DATE##/`date --utc`/g" \
 		$< > $@
 
