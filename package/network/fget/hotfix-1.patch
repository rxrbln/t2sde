--- fget/fget.c.vanilla	2019-02-07 10:17:45.512424271 +0000
+++ fget/fget.c	2019-02-07 10:18:13.596423951 +0000
@@ -150,15 +150,15 @@
   stralloc_cats(request,"\r\n\r\n");
 }
 
-inline int isdigit(char c) {
+int isdigit(char c) {
   return (c>='0' && c<='9');
 }
 
-inline int isresponsecode(char *s) {
+int isresponsecode(char *s) {
   return (isdigit(s[0]) && isdigit(s[1]) && isdigit(s[2]) && (s[3]==' ' || s[3]=='-'));
 }
 
-inline int iscrlf(char *s) {
+int iscrlf(char *s) {
   return *s=='\r' && s[1]=='\n';
 }
 
--- fget/readwrite.h.vanilla	2019-02-07 10:27:17.936417746 +0000
