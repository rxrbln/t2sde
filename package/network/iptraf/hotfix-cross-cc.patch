--- iptraf-3.0.0/support/Makefile.vanilla	2007-08-15 13:21:29.000000000 +0200
+++ iptraf-3.0.0/support/Makefile	2007-08-15 13:21:49.000000000 +0200
@@ -7,12 +7,12 @@
 
 libtextbox.a: $(OBJS)
 	rm -rf libtextbox.a
-	ar cq libtextbox.a $(OBJS)
-	ranlib libtextbox.a
+	$(AR) cq libtextbox.a $(OBJS)
+	$(RANLIB) libtextbox.a
 #	gcc -shared -o libtextbox.so $(OBJS)
 
 %.o: %.c *.h
-	gcc -O2 -g -Wall -fPIC $(INCLUDEDIR) -c -o $*.o $<
+	$(CC) -O2 -g -Wall -fPIC $(INCLUDEDIR) -c -o $*.o $<
 
 clean:
 	rm -rf *.o *~ libtextbox.a libtextbox.so
