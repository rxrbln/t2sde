Allow specifing raw, non C, non NUL terminated strings, e.g. for
option 67, bootfile-name on broken vintage Apple OpenFirmware, ...

--- dnsmasq-2.90/src/option.c.vanilla	2024-04-03 13:25:17.415189079 +0200
+++ dnsmasq-2.90/src/option.c	2024-04-03 14:10:41.063242164 +0200
@@ -1633,7 +1633,7 @@
 	}
       /* or names */
       else if (opt_len & (OT_NAME | OT_RFC1035_NAME | OT_CSTRING))
-	is_addr6 = is_addr = is_dec = is_hex = 0;
+	is_addr6 = is_addr = is_dec /*= is_hex */ = 0;
       
       if (found_dig && (opt_len & OT_TIME) && strlen(comma) > 0)
 	{
