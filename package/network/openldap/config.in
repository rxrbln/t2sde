if pkgcheck openldap X; then
	menu_begin MENU_PKG_OPENLDAP 'OpenLDAP Package Options'
		bool 'Client only, no daemons.' \
			SDECFG_PKG_OPENLDAP_CLIENTONLY 0
		text 'Install prefix for OpenLdap  Packages' SDECFG_PKG_OPENLDAP_CORE_PREFIX "opt/openldap"
		if pkgcheck heimdal X; then
			# FIXME: this belongs to heimdal's config.in but i
			# FIXME:  don't want another one-line-menu on Config
			bool 'Use LDAP as krb5 (heimdal) backend' \
				SDECFG_PKG_HEIMDAL_LDAP	0
		fi
	menu_end
fi
