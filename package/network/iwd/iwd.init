# Desc:
# Runlevel: 85 rcX
#

main_begin

	block_begin(start, `Starting iwd')
		D_libexecdir/iwd >/dev/null 2>/dev/null &
	block_end

	block_begin(stop, `Stopping iwd')
		check(`killall D_libexecdir/iwd')
	block_end

main_end
