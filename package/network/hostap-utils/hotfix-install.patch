--- hostap-utils-0.4.7/Makefile.vanilla	2007-03-23 15:07:24.000000000 +0100
+++ hostap-utils-0.4.7/Makefile	2007-03-23 15:08:54.000000000 +0100
@@ -2,6 +2,8 @@
 CFLAGS = -O2 -Wall
 endif
 
+prefix=/usr/local
+
 # Include directory for CVS version
 CFLAGS += -I../driver/modules
 
@@ -28,6 +30,9 @@
 
 hostap_rid.o: hostap_rid.c util.h
 
+install:
+	for i in $(all); do cp $$i $(DESTDIR)$(prefix)/bin/$$i; done
+
 clean:
 	rm -f prism2_srec hostap_crypt_conf hostap_diag hostap_rid \
 		hostap_io_debug *.o
