if pkgcheck licq X
then
	menu_begin MENU_PKG_LICQ 'LICQ Options'
		block_begin 3
			bool "Build the CLI" SDECFG_PKG_LICQ_CLI 0
			bool "Build the QT-GUI" SDECFG_PKG_LICQ_QTG 1
			bool "Build the KDE-GUI" SDECFG_PKG_LICQ_KDE 1
			bool "Build the Auto-Replier" SDECFG_PKG_LICQ_REPLY 1
			bool "Build the Forwarder" SDECFG_PKG_LICQ_EMAIL 1
			bool "Build the Remote Management Service Plugin" SDECFG_PKG_LICQ_RMS 0
			bool "Build the XOSD Plugin" SDECFG_PKG_LICQ_OSD 1
		block_end
	menu_end
fi
