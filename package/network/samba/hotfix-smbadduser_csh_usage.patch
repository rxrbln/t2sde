--- ./source3/smbadduser.in.orig	2006-01-16 22:50:47.000000000 +0000
+++ ./source3/smbadduser.in	2006-01-16 22:51:12.000000000 +0000
@@ -3,11 +3,11 @@
 # smbadduser - Written by Mike Zakharoff
 #
 
-prefix=@prefix@
-exec_prefix=@exec_prefix@
-LIBDIR=@libdir@
-PRIVATEDIR=@privatedir@
-CONFIGDIR=@configdir@
+set prefix=@prefix@
+set exec_prefix=@exec_prefix@
