--- ./source3/smbadduser.in.old	2006-11-01 15:38:14.000000000 +0100
+++ ./source3/smbadduser.in	2006-11-01 15:39:54.000000000 +0100
@@ -61,7 +61,7 @@
 	endif
 
 	echo "Adding: $unix to $smbpasswd"
-	/usr/bin/smbpasswd -a -n $unix
+	$prefix/bin/smbpasswd -a -n $unix
 	if ($unix != $ntid) then
 		echo "Adding: {$unix = $ntid} to $user_map"
 		echo "$unix = $ntid" >> $user_map
