if [ $prefix_auto = 1 ]; then
	if [ "$SDECFG_PKG_NAGIOS_PREFIX" ]; then
	  prefix="$SDECFG_PKG_NAGIOS_PREFIX"
	else
	  prefix="opt/nagios"
	fi
	set_confopt
fi
