 #include <cfloat>
 #include <cinttypes>
 #include <cmath>
@@ -587,6 +588,11 @@ static bool GetBuildConfiguration(JSContext* cx, unsigned argc, Value* vp) {
     return false;
   }
 
+  value = BooleanValue(std::endian::native == std::endian::big);
+  if (!JS_SetProperty(cx, info, "big-endian", value)) {
+    return false;
+  }
