--- firefox-152.0.6/xpcom/reflect/xptcall/md/unix/xptcinvoke_ppc_linux.cpp.vanilla	2026-07-13 21:35:59.000000000 +0200
+++ firefox-152.0.6/xpcom/reflect/xptcall/md/unix/xptcinvoke_ppc_linux.cpp	2026-07-18 18:39:42.783546566 +0200
@@ -44,11 +44,21 @@
     uint64_t tempu64;
 
     for(uint32_t i = 0; i < paramCount; i++, s++) {
-        if(s->IsPtrData()) {
-            if(s->type == nsXPTType::T_JSVAL)
-                tempu32 = (uint32_t) &s->ptr;
+        if(s->IsIndirect()) {
+            if(s->type == nsXPTType::T_JSVAL) {
+                // The SysV PPC ABI passes aggregates by reference, so the
+                // callee expects a JS::Handle*, i.e. a pointer to a slot
+                // holding the Value*. Store that slot in the unused tail
+                // of the 16-byte nsXPTCVariant union.
+                static_assert(sizeof(nsXPTCVariant::ExtendedVal) >=
+                              sizeof(JS::Value) + sizeof(void*),
+                              "no room for the JS::Value handle slot");
+                void** slot = (void**)((char*) &s->val + sizeof(JS::Value));
+                *slot = (void*) &s->val;
+                tempu32 = (uint32_t) slot;
+            }
             else
-                tempu32 = (uint32_t) s->ptr;
+                tempu32 = (uint32_t) &s->val.p;
         }
         else {
             switch(s->type) {
@@ -69,7 +79,7 @@
             }
         }
 
-        if (!s->IsPtrData() && s->type == nsXPTType::T_DOUBLE) {
+        if (!s->IsIndirect() && s->type == nsXPTType::T_DOUBLE) {
