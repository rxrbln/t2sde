+    // --- Indexed loads ---
+    case 21: {
+      // ldx: RT = [RA|0 + RB], 8 bytes
+      uint64_t ea = XFormEA(this, instr);
+      setRegister(rt, readDW(ea, instr));
+      break;
+    }
+    case 53: {
+      // ldux: RT = [RA + RB], update RA
+      uint64_t ea = XFormEAUpdate(this, instr);
+      setRegister(rt, readDW(ea, instr));
