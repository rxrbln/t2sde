+      }
+      break;
+    }
+    case 467: {
+      // mtspr: SPR = RS
+      uint32_t spr_lo = instr->raValue();
+      uint32_t spr_hi = instr->rbValue();
+      uint32_t spr = (spr_lo) | (spr_hi << 5);
+      int64_t val = getRegister(rt);
+      switch (spr) {
+        case 8:  // LR
+          setLR(val);
+          break;
+        case 9:  // CTR
+          setCTR(val);
+          break;
+        case 1:  // XER
