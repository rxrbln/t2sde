+// --- VSX (FPR-only subset) ---
+
+BufferOffset Assembler::as_mfvsrd(Register ra, FloatRegister xs) {
+  spew("mfvsrd\t%3s,%3s", ra.name(), xs.name());
+  return writeInst(XX1FormMfvsr(PPC_mfvsrd, ra.code(), xs.encoding()));
+}
