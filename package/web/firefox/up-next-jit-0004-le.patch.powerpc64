+  Register tag = extractTag(src, scratch);
+  Condition c = ma_cmp(tag, ImmTag(JSVAL_TAG_BOOLEAN), cond);
+  ma_cmp_set(dest, c);
+}
+
+template <typename T>
+void MacroAssembler::testStringSet(Condition cond, const T& src,
+                                   Register dest) {
