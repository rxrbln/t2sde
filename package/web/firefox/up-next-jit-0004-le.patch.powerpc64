+  as_mtfsb0(23);
+  as_fctiwz(fpscratch, input);
+  as_mfvsrd(output, fpscratch);
+  as_extsw(output, output);
+  as_mcrfs(cr0, 5);
+  ma_b(SOBit, oolEntry);
+}
