+      uint32_t bf = instr->bfValue();
+      bool l = instr->lBit();
+      if (l) {
+        setCRFieldCmp(bf, getRegister(ra), getRegister(rb));
+      } else {
+        setCRFieldCmp(bf, (int64_t)I32(getRegister(ra)),
+                      (int64_t)I32(getRegister(rb)));
+      }
+      break;
+    }
+    case 32: {
+      // cmpl (cmplw/cmpld): unsigned compare
+      uint32_t bf = instr->bfValue();
+      bool l = instr->lBit();
+      if (l) {
