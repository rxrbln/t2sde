+  PPC_stfs = 0xD0000000,
+  PPC_stfsu = 0xD4000000,
+  PPC_stfsx = 0x7C00052E,
+  PPC_sth = 0xB0000000,
+  PPC_sthcx = 0x7C0005AD,
+  PPC_sthx = 0x7C00032E,
