+  PPC_srawi = 0x7C000670,
+  PPC_srd = 0x7C000436,
+  PPC_srw = 0x7C000430,
+  PPC_stb = 0x98000000,
+  PPC_stbcx = 0x7C00056D,
+  PPC_stbx = 0x7C0001AE,
+  PPC_std = 0xF8000000,
+  PPC_stdcx = 0x7C0001AD,
+  PPC_stdu = 0xF8000001,
+  PPC_stdx = 0x7C00012A,
+  PPC_stfd = 0xD8000000,
+  PPC_stfdu = 0xDC000000,
