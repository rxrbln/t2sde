if pkgcheck webkit X; then
	menu_begin MENU_PKG_WEBKIT 'WebKit Package Options'
		choice SDECFG_PKG_WEBKIT_LIB gtk \
			gtk "Build gtk+ library" \
			qt4 "Build Qt4 library" \
			qtcore "Build QtCore library"
	menu_end
fi
