--- Pale-Moon/platform/media/webrtc/trunk/build/common.gypi.vanilla	2024-12-31 21:20:31.839997257 +0100
+++ Pale-Moon/platform/media/webrtc/trunk/build/common.gypi	2024-12-31 21:21:00.899997256 +0100
@@ -117,7 +117,7 @@
             # Anything else gets passed through, which probably won't work very
             # well; such hosts should pass an explicit target_arch to gyp.
             'host_arch%':
