if pkgcheck zope X
then
	menu_begin MENU_PKG_ZOPE 'Zope Package Options'
	text 'Install prefix for Zope application server' \
		SDECFG_PKG_ZOPE_PREFIX "opt/zope"
	text 'Zope Product Directory' \
		SDECFG_PKG_ZOPE_PRODDIR "$SDECFG_PKG_ZOPE_PREFIX/products"
	menu_end
fi
