Let our /etc/inittab decide which tty to run on.

  - NoTag <notag@t2sde.org>

--- greetd-0.9.0/config.toml.vanilla	2024-01-06 12:00:25.182732861 +0100
+++ greetd-0.9.0/config.toml	2024-01-06 12:00:36.464385005 +0100
@@ -1,7 +1,7 @@
 [terminal]
 # The VT to run the greeter on. Can be "next", "current" or a number
 # designating the VT.
-vt = 1
+vt = current
 
 # The default session, also known as the greeter.
 [default_session]
