[D] 011d952b8f4196c4c5c3cae82880b2fd5effd79a145ff7d1d499a515 librep-0.92.7.tar.gz https://github.com/SawfishWM/librep/archive/librep-0.92.7/

autogen=1
case $arch in
	powerpc|powerpc64|ia64)
		var_append confopt ' ' --with-stack-direction=1
	;;
esac

