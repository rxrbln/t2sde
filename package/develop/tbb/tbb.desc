[D] 9af99e122d644d4e1bc2c3701c6195e71f0db421906c49f69db95cdf oneTBB-2023.0.0.tar.gz https://github.com/oneapi-src/oneTBB/archive/v2023.0.0/

var_append cmakeopt ' ' -DTBB_TEST=OFF
var_append GCC_WRAPPER_REMOVE ' ' -fcf-protection=*
[[ $arch == x86* ]] && var_append GCC_WRAPPER_INSERT ' ' -mwaitpkg
