--- iax-0.2.2/src/Makefile.in.vanilla	2007-06-17 22:04:39.495943088 +0200
+++ iax-0.2.2/src/Makefile.in	2007-06-17 22:05:07.409533793 +0200
@@ -304,11 +304,11 @@
 
 
 install:
-	mkdir -p $(includedir)/iax
-	install -m 644 md5.h $(includedir)/iax
-	install -m 644 frame.h $(includedir)/iax
-	install -m 644 iax.h $(includedir)/iax
