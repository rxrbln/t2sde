if pkgcheck distcc X
then
	bool 'Distribute compile jobs (distcc) wherever possible' \
		     SDECFG_PKG_DISTCC_USEIT 0
	if [ "$SDECFG_PKG_DISTCC_USEIT" == "1" ]; then
	block_begin 3
		bool 'Use hosts /etc/resolve.conf for name resolving' \
		     SDECFG_PKG_DISTCC_HOST_RESOLV 1
		text 'Remote hosts (nodes) to be used' \
		     SDECFG_PKG_DISTCC_HOSTS "localhost"
	block_end 3
	fi
fi
