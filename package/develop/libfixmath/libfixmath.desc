makeinstopt=

install-lib() {
	find -type f -name '*.a' -exec install -v {} $root$libdir/ \;
	rm -f libfixmath/{Make*,*.c,*.txt,*.cmake,*.cbp}
	cp -frv libfixmath $root$includedir/
}
hook_add postmake 5 install-lib
