--- llvm-project-22.1.0.src/lib/TargetParser/Triple.cpp.vanilla	2026-03-07 12:02:49.396192971 +0100
+++ llvm-project-22.1.0.src/lib/TargetParser/Triple.cpp	2026-03-07 12:05:44.345634174 +0100
@@ -70,7 +70,7 @@
   case shave:          return "shave";
   case sparc:          return "sparc";
   case sparcel:        return "sparcel";
-  case sparcv9:        return "sparcv9";
+  case sparcv9:        return "sparcv64";
   case spir64:         return "spir64";
   case spir:           return "spir";
   case spirv:          return "spirv";
@@ -482,8 +482,10 @@
       .Case("riscv64be", riscv64be)
       .Case("hexagon", hexagon)
       .Case("sparc", sparc)
+      .Case("sparcv8", sparc)
+      .Case("sparcv9", sparc)
       .Case("sparcel", sparcel)
-      .Case("sparcv9", sparcv9)
+      .Case("sparc64", sparcv9)
       .Case("s390x", systemz)
       .Case("systemz", systemz)
       .Case("tce", tce)
@@ -633,9 +635,9 @@
           .Case("riscv64be", Triple::riscv64be)
           .Case("hexagon", Triple::hexagon)
           .Cases({"s390x", "systemz"}, Triple::systemz)
-          .Case("sparc", Triple::sparc)
+          .Cases({"sparc", "sparcv8", "sparcv9"}, Triple::sparc)
           .Case("sparcel", Triple::sparcel)
-          .Cases({"sparcv9", "sparc64"}, Triple::sparcv9)
+          .Case("sparc64", Triple::sparcv9)
           .Case("tce", Triple::tce)
           .Case("tcele", Triple::tcele)
           .Case("xcore", Triple::xcore)
