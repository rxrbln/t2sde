     T.setArch(UnknownArch);
@@ -1943,6 +1993,7 @@ Triple Triple::get64BitArchVariant() const {
   case Triple::systemz:
   case Triple::ve:
   case Triple::wasm64:
+  case Triple::ia64:
   case Triple::x86_64:
     // Already 64-bit.
     break;
@@ -2019,6 +2070,7 @@ Triple Triple::getBigEndianArchVariant() const {
   case Triple::ve:
