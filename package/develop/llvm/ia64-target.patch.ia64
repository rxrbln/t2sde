     return 64;
   }
@@ -1824,6 +1873,7 @@ Triple Triple::get32BitArchVariant() const {
   case Triple::bpfeb:
   case Triple::bpfel:
   case Triple::msp430:
+  case Triple::ia64:
   case Triple::systemz:
