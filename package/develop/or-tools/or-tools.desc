[I] Google's software suite for combinatorial optimization

[T] Fast and portable software suite for solving combinatorial optimization
[T] problems.

[U] https://github.com/google/or-tools

[A] OR-tools Project
[M] René Rebe <rene@exactco.de>

[C] extra/development
[F] CROSS

# are deps of coin-cbc but are marked as deps if not manually marked as opts
[E] opt coin-utils coin-osi coin-glpk coin-clp

[L] APL
[V] 9.15

[D] d13c5a5b3a4d4bcdffb30dc4da6a05e9205f9c70be36b2268c497965 or-tools-9.15.tar.gz https://github.com/google/or-tools/archive/v9.15/

rungo=0
hook_add preconf 5 "rm -vf Makefile"

var_append cmakeopt ' ' "-DBUILD_TESTING=OFF -DBUILD_EXAMPLES=OFF -DBUILD_SAMPLES=OFF"

# TODO: enable once we have the necessary packages
var_append cmakeopt ' ' "-DUSE_PDLP=OFF"
var_append cmakeopt ' ' "-DUSE_HIGHS=ON -DUSE_SCIP=ON"

pkginstalled coin-cbc && var_append cmakeopt ' ' -DUSE_COINOR=ON || var_append cmakeopt ' ' -DUSE_COINOR=OFF
pkginstalled glpk && var_append cmakeopt ' ' -DUSE_GLPK=ON || var_append cmakeopt ' ' -DUSE_GLPK=OFF
