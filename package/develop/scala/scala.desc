[I] A scalable multiplatform programming language

[T] A programming language that scales with you: from small scripts to large
[T] multiplatform applications.

[U] https://www.scala-lang.org/

[A] École Polytechnique Fédérale
[M] René Rebe <rene@exactco.de>

[C] extra/development
[F] CROSS

[E] add sbt openjdk

[L] GPL
[V] 3.8.3

[D] 50bb272b895504d48861855f7053770dc55839493fc1ec322dd56dc8 scala3-3.8.3.tar.gz https://github.com/scala/scala3/archive/refs/tags/3.8.3/

runmake=0

build() {
	sbt dist/Universal/packageBin
}
hook_add inmake 5 build

install() {
	unzip -d dist/target/universal/ dist/target/universal/scala3-3.8.3-bin-SNAPSHOT.zip
	mkdir -p $root/opt/scala
	cp -r dist/target/universal/scala3-3.8.3-bin-SNAPSHOT/* $root/opt/scala/

	mkdir -p $root$bindir
	for bin in scala scalac scaladoc; do
		ln -sf $root/opt/scala/bin/$bin $root$bindir/$bin
	done
}
hook_add postmake 5 install
