var_append cmakeopt ' ' '-DMYGUI_RENDERSYSTEM=1 -DMYGUI_BUILD_DEMOS=OFF'
var_append cmakeopt ' ' '-DMYGUI_BUILD_TOOLS=OFF -DMYGUI_BUILD_PLUGINS=OFF'
var_append cmakeopt ' ' -DMYGUI_DONT_USE_OBSOLETE=ON
