dirlist=/usr/share/aclocal/dirlist
echo -n "Create aclocal dirlist..."
for dir in {/usr/X11,/opt/*,/usr/local}/share/aclocal; do
	[ -d $dir ] && echo $dir
done > $dirlist
echo " Done."
