prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: NSPR
Description: Netscape Portable Runtime
Version: @NSPR_VER@
Libs: -lpthread -L${libdir} -lplds4 -lplc4 -lnspr4 -ldl -Wl,-R${libdir}
Cflags: -I${includedir}
