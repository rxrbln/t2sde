[I] Mixed Integer Linear Programming solver

[T] Mixed Integer Linear Programming (MILP) solver lp_solve solves pure linear,
[T] (mixed) integer/binary, semi-cont and special ordered sets (SOS) models.

[U] https://lp-solve.github.io/

[A] lp_solve
[M] andrei32

[C] base/library
[F] CROSS

[L] LGPL
[V] 5.5.2.14
[P] X -----5---9 201.000

[D] a982ce2fb51d49f1a6d2faa594ce9033a7c6e58ecd8d15f70b760825 lp_solve_5.5.2.14_source.tar.gz https://github.com/lp-solve/lp_solve/releases/download/5.5.2.14/

runmake=0

lp_solve_inst() {
	cd lp_solve
	chmod +x ccc
	./ccc
	install -Cv bin/*/lp_solve $root$bindir/
	cd ..
}
hook_add premake 5 lp_solve_inst

lpsolve55_inst() {
	cd lpsolve55
	chmod +x ccc
	./ccc
	install -Cv bin/*/liblp* $libdir/
	cd ..
}
hook_add premake 6 lpsolve55_inst

include_inst() {
	rm -rf {bfp,colamd,demo,lp_solve,lpsolve55,shared}
	rm -f *.{c,l,y,def,txt}
	rm -f LIC*
	cd ..
	mv lp_solve lpsolve
	cp -rv lpsolve $includedir/
}
hook_add premake 7 include_inst
