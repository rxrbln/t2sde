[V] 2026-05

[D] 196f7188e6d1002fd2386b84c5a2ce0ca13d3556cc44e0e970c575ba odin-dev-2026-05.tar.gz https://github.com/odin-lang/Odin/archive/refs/tags/dev-2026-05/

var_append makeopt ' ' release-native
makeinstopt=
hook_add postmake 5 'find {odin,base,core,vendor} -type f -exec install -Dm 755 "{}" "$root/opt/odin/bin/{}" \;'
