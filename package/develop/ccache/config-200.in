if pkgcheck ccache X
then
	bool 'Use compiler cache (ccache) where possible' \
				SDECFG_PKG_CCACHE_USEIT 0
	if [ "$SDECFG_PKG_CCACHE_USEIT" == "1" ]; then
	block_begin 3
		text 'Maximum size of per package on-disk cache' \
				SDECFG_PKG_CCACHE_MAX '1000M'
		bool 'Enable cache automatic cleaning up' \
				SDECFG_PKG_CCACHE_CLEANUP 1
	block_end
	fi
fi
