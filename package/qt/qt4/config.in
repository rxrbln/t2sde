if pkgcheck qt4 X; then
 	menu_begin MENU_PKG_QT4 'Qt4 Package Options'
		text 'Install prefix for Qt4' SDECFG_PKG_QT4_PREFIX "opt/qt4"
		bool 'Enable exception support' SDECFG_PKG_QT4_EXCEPTION 1
		bool 'Enable STL support' SDECFG_PKG_QT4_STL 1
		bool 'Enable Qt virtual framebuffer support' SDECFG_PKG_QT4_QVFB 0
	menu_end
fi
