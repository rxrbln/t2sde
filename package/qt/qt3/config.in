if pkgcheck qt3 X; then
 	menu_begin MENU_PKG_QT 'Qt Package Options'
		text 'Install prefix for Qt 3' SDECFG_PKG_QT_PREFIX "opt/qt3"
		bool 'Enable exception support' SDECFG_PKG_QT_EXCEPTION 0
		bool 'Enable STL support' SDECFG_PKG_QT_STL 1
	menu_end
fi
