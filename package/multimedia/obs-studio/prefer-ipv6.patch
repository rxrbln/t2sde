--- obs-studio-23.2.1/plugins/obs-outputs/librtmp/rtmp.c.vanilla	2019-08-08 20:01:31.499928242 +0200
+++ obs-studio-23.2.1/plugins/obs-outputs/librtmp/rtmp.c	2019-08-08 20:02:02.179929514 +0200
@@ -859,10 +859,10 @@
         goto finish;
     }
 
-    // prefer ipv4 results, since lots of ISPs have broken ipv6 connectivity
+    // prefer ipv6 results, since lots of ISPs have broken ipv6 connectivity
     for (ptr = result; ptr != NULL; ptr = ptr->ai_next)
