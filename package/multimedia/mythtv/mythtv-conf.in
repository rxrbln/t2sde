prefix=/opt/mythtv
set_confopt

# Mythtv needs Qt3
pkgprefix -t qt
export PATH=$(pkgprefix bindir qt):$PATH

# brain damaged hardcoded path... have to replace it...
fix_mythtv_prefix() {
	destdir="$root/$prefix" destdir="`echo $destdir | tr -s '/'`"
	grep /usr/local * -R | sed 's,:.*,,' | xargs -n1 sed -i "s,/usr/local,$destdir,g"
}

# has non-standard configure script, so some options do not pass through eval_config_command
mythtv_config ()
{
	local confcmd=$(eval echo "$configprefix $configscript $confopt")
	echo "Running $confcmd"
	eval "$confcmd"
}
