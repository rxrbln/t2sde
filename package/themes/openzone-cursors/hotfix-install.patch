--- openzone-cursors-1.2.9/Makefile.vanilla	2020-09-21 12:29:05.250701914 +0000
+++ openzone-cursors-1.2.9/Makefile	2020-09-21 12:32:21.190702007 +0000
@@ -16,7 +16,7 @@
 
 install: $(themes)
 	install -dm755 $(DESTDIR)/share/icons
-	mv $(themes) $(DESTDIR)/share/icons
+	for t in $(themes); do mkdir $(DESTDIR)/share/icons/$$t; cp -vrf $$t/* $(DESTDIR)/share/icons/$$t/; done
 
 pack: $(themes)
