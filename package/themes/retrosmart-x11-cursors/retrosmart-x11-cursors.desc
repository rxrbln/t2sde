[D] 5240d94d0f7fc3eb712178bcf21d3fd24ec000c25e845136c3ed4220 retrosmart-x11-cursors-3.1a.tar.gz https://github.com/mdomlop/retrosmart-x11-cursors/archive/3.1a/

makeinstopt=

retrosmart_x11_cursors() {
	mkdir -p $root$datadir/icons/
	cp -rfv retrosmart-xcursor-* $root$datadir/icons/
}
hook_add postmake 5 retrosmart_x11_cursors
