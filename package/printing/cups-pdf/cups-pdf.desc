[I] A PDF print driver for CUPS

[T] A print driver for CUPS generating PDF files for each print job.

[U] https://www.cups-pdf.de/

[A] Volker C. Behr <vrbehr@cip.physik.uni-wuerzburg.de>
[M] René Rebe <rene@exactco.de>

[C] extra/printing
[F] CROSS

[L] GPL
[V] 3.0.3
[P] X -----5---9 122.900

[D] fcbfd9a6ac3568e36909ffe364cfc0a505b46000279427a2bb1e8538 cups-pdf_3.0.3.tar.gz https://www.cups-pdf.de/src/

runmake=0
hook_add inmake 5 "$CC -o cups-pdf src/cups-pdf.c"

cups_pdf_install() {
	mkdir -p $root$libdir/cups/backend
	cp -fv cups-pdf $root$libdir/cups/backend/
	cp -fv extra/cups-pdf.conf $root/etc/cups/
	mkdir -p $root$datadir/cups/model
	cp -fv extra/PostscriptColor.ppd* $root$datadir/cups/model/
}
hook_add postmake 5 cups_pdf_install
