 	switch (pS3->s3Bpp) {
 	case 1:
 		/* XXX Trio series only */
@@ -104,10 +105,31 @@
 {
 	S3Ptr pS3 = S3PTR(pScrn);
 	int vgaCRIndex = pS3->vgaCRIndex, vgaCRReg = pS3->vgaCRReg;
+	unsigned char xoff, yoff;
+
+	/* the cursor can only be placed at positive coordinates, a
+	   partially off-screen cursor is done by starting inside the
+	   64x64 pattern instead */
+	if (x < 0) {
+		xoff = (-x) & 0x3f;
+		x = 0;
+	} else
+		xoff = 0;
+
+	if (y < 0) {
+		yoff = (-y) & 0x3f;
+		y = 0;
+	} else
+		yoff = 0;
 
 	outb(vgaCRIndex, 0x39);
 	outb(vgaCRReg, 0xa5);
 
+	outb(vgaCRIndex, 0x4e);
+	outb(vgaCRReg, xoff);
+	outb(vgaCRIndex, 0x4f);
+	outb(vgaCRReg, yoff);
+
 	outb(vgaCRIndex, 0x46);
 	outb(vgaCRReg, x >> 8);
 	outb(vgaCRIndex, 0x47);
