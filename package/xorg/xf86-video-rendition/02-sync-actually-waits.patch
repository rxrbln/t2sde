-        return;
-    }
-
     /* restart the ucode */
+    waitfifo(4);
     verite_out32(iob, 0);     /* a0 - ucode init command */
     verite_out32(iob, 0);     /* a1 - 1024 byte context store area */
     verite_out32(iob, 0);     /* a2 */
@@ -524,7 +511,16 @@
     verite_out32(iob, pRendition->board.mode.virtualwidth  *
 	    (pRendition->board.mode.bitsperpixel>>3));
     verite_out32(iob, (pRendition->board.mode.stride1<<12) |
-	    (pRendition->board.mode.stride0<<8)); 
+	    (pRendition->board.mode.stride0<<8));
+
+    /* The csucode's pixel engine sync (a0=2) produces no result word, so it
+       can only be observed indirectly: the RISC executes strictly in order, so
+       a readback that retires *after* the restart proves everything queued
+       before it -- including the pixel engine sync -- has completed. */
+    waitfifo(2);
+    verite_out32(iob, CMD_GET_PIXEL);
+    verite_out32(iob, 0);
+    waitfifoout("pixel engine idle");
