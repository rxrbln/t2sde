# --- T2-COPYRIGHT-END ---

echo "Running mkfontscale and mkfontdir ..."
for dir in /usr/X11/share/fonts/{*,*/*}/; do
	[ -d $dir ] || continue
	echo "  $dir"
	mkfontscale $dir
	mkfontdir $dir
done

echo

if which fc-cache > /dev/null; then
	echo "Running fc-cache ..."
	fc-cache -v --system-only
fi
