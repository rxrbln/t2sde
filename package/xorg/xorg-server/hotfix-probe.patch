--- xorg-server/hw/xfree86/common/xf86pciBus.c.vanilla	2026-07-05 11:17:38.342765496 +0200
+++ xorg-server/hw/xfree86/common/xf86pciBus.c	2026-07-05 11:19:59.603159838 +0200
@@ -1117,6 +1117,10 @@
     case 0x3d3d:
         driverList[0] = "glint";
         break;
+    case 0x104c:
+	if (dev->device_id == 0x3d07)
+		driverList[0] = "glint";
+	break;
     case 0x105d:
         driverList[0] = "i128";
         break;
@@ -1258,6 +1258,9 @@
     case 0x15ad:
         driverList[0] = "vmware";
         break;
+    case 0x100e:
+        driverList[0] = "p9000";
+        break;
     case 0x18ca:
         if (dev->device_id == 0x47)
             driverList[0] = "xgixp";
