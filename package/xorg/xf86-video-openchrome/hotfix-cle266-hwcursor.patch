+/*
+ * Upload a two-color cursor image for the CLE266 / KM400 UniChrome cursor
+ * engine.  The X server hands us a 32x32 two-plane (AND source + mask) image
+ * (256 bytes) which is copied verbatim into video RAM, and the cursor engine
+ * is pointed at it via VIA_REG_CURSOR_MODE (byte offset in the low address
+ * bits, cursor control in bits [1:0]).
+ */
+static void
+iga_crtc_load_cursor_image(xf86CrtcPtr crtc, CARD8 *image)
+{
+    ScrnInfoPtr pScrn = crtc->scrn;
+    VIAPtr pVia = VIAPTR(pScrn);
+    drmmode_crtc_private_ptr iga = crtc->driver_private;
+    void *dst;
+    /* 32x32, two planes (AND + XOR), 1 bit per pixel per plane. */
+    unsigned int monoSize = 2 * (32 / 8) * 32;
+    CARD32 mode;
+
+    if (!viaCursorOldEngine(pVia)) {
+        return;
+    }
+
+    if (monoSize > iga->cursor_bo->size) {
+        monoSize = iga->cursor_bo->size;
+    }
+
+    mode = VIAGETREG(VIA_REG_CURSOR_MODE);
+
+    /* Disable the cursor engine while its image is replaced. */
+    VIASETREG(VIA_REG_CURSOR_MODE, mode & 0xFFFFFFFE);
+
+    dst = drm_bo_map(pScrn, iga->cursor_bo);
+    memset(dst, 0x00, iga->cursor_bo->size);
+    memcpy(dst, image, monoSize);
+    drm_bo_unmap(pScrn, iga->cursor_bo);
+
+    /* Point the engine at the image (byte offset in video RAM) while
+     * preserving the current enable / control bits. */
+    VIASETREG(VIA_REG_CURSOR_MODE,
+              (iga->cursor_bo->offset & 0xFFFFFFFC) | (mode & 0x03));
+}
+
