 static void
 iga_crtc_set_cursor_colors(xf86CrtcPtr crtc, int bg, int fg)
 {
     ScrnInfoPtr pScrn = crtc->scrn;
+    VIAPtr pVia = VIAPTR(pScrn);
     drmmode_crtc_private_ptr iga = crtc->driver_private;
     xf86CrtcConfigPtr xf86_config = XF86_CRTC_CONFIG_PTR(pScrn);
 
+    if (viaCursorOldEngine(pVia)) {
+        /* Two-color cursor: foreground / background come from registers. */
+        VIASETREG(VIA_REG_CURSOR_BG, bg);
+        VIASETREG(VIA_REG_CURSOR_FG, fg);
+        return;
+    }
+
     if (xf86_config->cursor_fg)
         return;
 
