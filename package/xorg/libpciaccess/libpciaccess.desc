[P] X ?----5---9 112.440

[ "$SDECFG_LIBC" = musl ] && var_append GCC_WRAPPER_INSERT ' ' -D_LARGEFILE64_SOURCE

[D] 139d214f512c622894c41076aed985e04aba6769411a0beddcf7eff9 libpciaccess-0.19.tar.xz http://xorg.freedesktop.org/archive/individual/lib/

if atstage cross; then
	val=no
	[[ $arch = x86* ]] && val=yes

	hook_add preconf 5 "echo 'ac_cv_file__usr_include_asm_mtrr_h=$val' >> config.cache"
	unset val
fi
