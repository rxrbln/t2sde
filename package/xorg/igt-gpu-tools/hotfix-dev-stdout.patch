--- igt-gpu-tools-v2.4-e6b603e4984e4ce30fe1cc2705734d0f130e0550/scripts/generate_iga64_codes.vanilla	2026-04-10 20:32:07.718087114 -0400
+++ igt-gpu-tools-v2.4-e6b603e4984e4ce30fe1cc2705734d0f130e0550/scripts/generate_iga64_codes	2026-04-10 20:42:34.975879946 -0400
@@ -35,11 +35,12 @@
 OBJ=${@:OPTIND}
 
 # read all assemblies into ASMS array
+tmpfile=$(mktemp)
 ASMS=()
 while  read -d $'\0' asm; do
     test -z "$asm" && continue
     ASMS+=( "$asm" )
-done < <(objcopy --dump-section .iga64_assembly=/dev/stdout $OBJ /dev/null)
+done < <(objcopy --dump-section .iga64_assembly=$tmpfile $OBJ /dev/null)
 
 # check if we need to recompile - checksum difference and compiler present
 MD5_ASMS="$(md5sum <<< "$(< $IGT_SRCDIR/lib/iga64_macros.h) ${ASMS[@]}" | cut -b1-32)"
