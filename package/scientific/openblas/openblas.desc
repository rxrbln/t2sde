[I] Fast BSD-licensed BLAS based on gotoBLAS2

[T] Fast BSD-licensed BLAS based on gotoBLAS2.

[U] https://www.openblas.net/

[A] Openblas Authors
[M] René Rebe <rene@exactco.de>

[C] extra/base
[F] OBJDIR

[E] opt lapack

[L] BSD
[V] 0.3.34

[D] 3a74f0c2123db6fbb0091670cc8da5e1a5bd666a551f3ff6b0d07592 openblas-0.3.34.tar.gz https://github.com/xianyi/OpenBLAS/archive/v0.3.34/

GCC_WRAPPER_BYPASS=1 # TODO: flexible configure their SIMD optimizations
var_append cmakeopt ' ' -DBUILD_TESTING=OFF
pkginstalled lapack || var_append cmakeopt ' ' -DBUILD_WITHOUT_LAPACK=ON
var_append makeinstopt ' ' OPENBLAS_LIBRARY_DIR=$libdir
[ "$SDECFG_STATIC" = 1 ] || var_append cmakeopt ' ' -DBUILD_SHARED_LIBS=ON
