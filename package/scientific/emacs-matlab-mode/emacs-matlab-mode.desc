[I] Matlab mode for Emacs

[T] Matlab-mode for Emacs.

[U] https://github.com/mathworks/Emacs-MATLAB-Mode

[A] Matt Wette <mwette@alumni.caltech.edu>
[A] Eric M. Ludlam <eludlam@mathworks.com>
[M] René Rebe <rene@exactco.de>

[C] extra/scientific extra/editor

[L] GPL3
[V] 8.2.0

[D] a56fef5220cab5a6b5b8b95534a1bfacd114ebd4a31f4cccf58f3aab matlab-mode-8.2.0.tar.gz https://github.com/mathworks/Emacs-MATLAB-Mode/archive/refs/tags/

var_append makeopt ' ' lisp
makeinstopt=

matlab_mode_main() {
	mkdir -p $root/usr/share/emacs/site-lisp/matlab
	cp -fv *.el* $root/usr/share/emacs/site-lisp/matlab/
}
hook_add postmake 5 matlab_mode_main
