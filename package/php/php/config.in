if pkgcheck php X; then
	menu_begin MENU_PKG_PHP 'PHP Package Options'
		bool 'Enable BC style precision math functions' SDECFG_PKG_PHP_BCMATH 1
		bool 'Force usage of shared modules' SDECFG_PKG_PHP_FORCESHARED 0
		bool 'Enable mbstring ' SDECFG_PKG_PHP_MBSTRING 0
		text 'Extra configure options' SDECFG_PKG_PHP_EXTRACONFOPT ''
		choice SDECFG_PKG_PHP_CGIAPI apache \
			apache Apache_APXS_Support \
			fastcgi FastCGI_Support \
			FPM     FPM_FastCGI_Process_Manager
	menu_end
fi
