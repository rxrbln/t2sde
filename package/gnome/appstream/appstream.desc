[I] A library providing methods for reading and writing AppStream metadata

[T] This library provides GObjects and helper methods to make it easy to read
[T] and write AppStream metadata.

[U] https://distributions.freedesktop.org/wiki/AppStream

[A] Matthias Klumpp <matthias@tenstral.net>
[M] René Rebe <rene@exactco.de>

[C] extra/game extra/desktop/gnome
[F] CROSS

[L] GPL
[V] 1.1.2
[P] X ?----5---9 161.650

[D] 9a4088f6badb8fbb0a6924171f02000beccc93110b7fde40e20c840c AppStream-1.1.2.tar.xz https://www.freedesktop.org/software/appstream/releases/

hook_add prepatch 5 "rm -rvf subprojects"

atstage cross && PKG_CONFIG_PATH="$PKG_CONFIG_PATH:$SYSPKG_CONFIG_PATH"
atstage cross && PKG_CONFIG_LIBDIR="$PKG_CONFIG_LIBDIR:$SYSPKG_CONFIG_LIBDIR"

var_append mesonopt ' ' -Ddocs=false
pkginstalled gobject-introspection || var_append mesonopt ' ' -Dgir=false
pkginstalled vala && var_append mesonopt ' ' -Dvapi=true
# TODO: fix meson to cross compile qt correctly
pkginstalled qt6base && var_append mesonopt ' ' -Dqt=true &&
	atstage cross &&
	var_append PATH : "$root/TOOLCHAIN/cross/qt/bin:$root/TOOLCHAIN/cross/qt/libexec/qt6" &&
	var_append GCC_WRAPPER_FILTER '|' "sed 's,-isystem/usr/,-isystem$root/usr/,'"

pkginstalled bash-completion || var_append mesonopt ' ' -Dbash-completion=false
pkginstalled libstemmer || var_append mesonopt ' ' -Dstemming=false
pkginstalled systemd || var_append mesonopt ' ' -Dsystemd=false
