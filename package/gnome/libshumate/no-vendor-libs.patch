Don't try to build depencies behind our back if we didn't not ask to.

  - NoTag <notag@t2sde.org>

--- libshumate-1.5.3/meson.build.vanilla	2026-03-05 15:01:55.156430283 +0100
+++ libshumate-1.5.3/meson.build	2026-03-05 15:03:06.567177644 +0100
@@ -78,7 +78,7 @@
     'with_sysprofd=none',
     'help=false',
   ],
-  fallback: ['sysprof', 'libsysprof_capture_dep'],
+  #fallback: ['sysprof', 'libsysprof_capture_dep'],
 )
 if libsysprof_capture_dep.found()
   add_project_arguments('-DSHUMATE_HAS_SYSPROF=1', language: 'c')
@@ -87,7 +87,7 @@
 if get_option('gtk_doc')
   dependency('gi-docgen',
     version: '>= 2021.1',
-    fallback: ['gi-docgen', 'dummy_dep'],
+    #fallback: ['gi-docgen', 'dummy_dep'],
     native : true,
   )
   gidocgen = find_program('gi-docgen')
