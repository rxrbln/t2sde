if pkgcheck glib X
then
	menu_begin MENU_PKG_GNOME2 'GNOME Package Options'
		text 'Install prefix for GNOME Packages' \
			SDECFG_PKG_GNOME2_CORE_PREFIX "opt/gnome"
	menu_end
fi
