[I] GObject-based wrapper around the Exiv2 library

[T] GObject-based wrapper around the Exiv2 library.

[U] https://wiki.gnome.org/Projects/gexiv2

[A] Gexiv2 Authors
[M] René Rebe <rene@exactco.de>

[C] extra/base
[F] CROSS

[V] 0.16.1
[L] GPL
[P] X -----5---9 154.800

[CV-FLAGS] NO-MAJOR
[D] 8cad6bf387bb6569ac4e440eedce4c04a0214d048b96a1e4bffa6021 gexiv2-0.16.1.tar.bz2 https://gitlab.gnome.org/GNOME/gexiv2/-/archive/0.16.1/

. $base/package/*/*/gnome-conf.in

var_append GCC_WRAPPER_APPEND ' ' -DEXIV2API=

pkginstalled python gobject-introspection || var_append mesonopt ' ' -Dpython3=false
pkginstalled gobject-introspection || var_append mesonopt ' ' -Dintrospection=false
pkginstalled pygobject || var_append mesonopt ' ' -Dpython3=false
pkginstalled vala || var_append mesonopt ' ' -Dvapi=false
