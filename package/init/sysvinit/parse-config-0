# on stage 9 we detect default init
if atstage rebuild; then
	x="$(grep -l ' sbin/init$' $root/var/adm/flists/* | sed -e 's,.*/,,g')"
	[ "$x" ] && SDECFG_INIT="$x"
fi

# an old config will not have SDECFG_INIT set, and sysvinit is the default
[ -z "$SDECFG_INIT" ] && SDECFG_INIT="sysvinit"
