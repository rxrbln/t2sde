[M] Boudewijn van der Heide <boudewijn@delta-utec.com>

[C] extra/development

[L] MIT
[V] 0.7.3
[P] X -----5---9 122.000

[D] 21eebc3c81f79b08559aab517f6207eeec427132bc80c9624aa3eec7 ronn-0.7.3.tar.gz https://github.com/rtomayko/ronn/archive/0.7.3/

runmake=0

hook_add prepatch 5 "sed -i '/has_rdoc/d' ronn.gemspec"
hook_add inmake 5 "gem build ronn.gemspec && gem install --local ronn-0.7.3.gem --no-document --bindir=/usr/bin --ignore-dependencies"
