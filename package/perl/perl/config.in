if pkgcheck perl X
then
	menu_begin MENU_PKG_PERL5 'Perl 5 Package Options'
		text 'Host name' SDECFG_PKG_PERL5_HOST_NAME "localhost"
		text 'Site prefix' SDECFG_PKG_PERL5_SITE_PREFIX "usr"
		text 'Vendor prefix' SDECFG_PKG_PERL5_VENDOR_PREFIX "opt"
		bool 'Use threads' SDECFG_PKG_PERL5_THREADS 0
		bool 'Build shared library' SDECFG_PKG_PERL5_SHARED 1
		if pkgcheck bdb33 X; then
		bool 'Force usage of BerkleyDB 3.3 (Compatibility)' SDECFG_PKG_PERL5_USE_DB3 1
		fi
	menu_end
fi
