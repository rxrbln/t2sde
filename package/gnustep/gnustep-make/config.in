if pkgcheck gnustep-make X
then
	menu_begin MENU_PKG_GNUSTEP 'GNUstep package Options'
		text 'Install prefix for GNUstep packages' \
			SDECFG_PKG_GNUSTEP_CORE_PREFIX "opt/gnustep"
	menu_end
fi
