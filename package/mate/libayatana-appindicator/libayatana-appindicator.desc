[P] X -----5---9 179.410

[D] 597be79188e8dacda92a938b4396dee594ed18272c8e4c82c7a45f1f libayatana-appindicator-0.6.0.tar.gz https://github.com/AyatanaIndicators/libayatana-appindicator/archive/refs/tags/0.6.0/

var_append GCC_WRAPPER_APPEND ' ' -L$root$(pkgprefix libdir glib)

pkginstalled mono || var_append cmakeopt ' ' -DENABLE_BINDINGS_MONO=OFF
pkginstalled vala || var_append cmakeopt ' ' -DENABLE_BINDINGS_VALA=OFF
var_append cmakeopt ' ' -DENABLE_GTKDOC=OFF
