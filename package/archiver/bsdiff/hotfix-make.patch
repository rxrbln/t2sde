--- bsdiff-4.3/Makefile	2005-08-17 00:14:10.000000000 +0200
+++ bsdiff-4.3-fixed/Makefile	2007-10-19 09:09:04.000000000 +0200
@@ -1,4 +1,5 @@
-CFLAGS		+=	-O3 -lbz2
+CFLAGS		+=	-O3
+LDLIBS		+=	-lbz2
 
 PREFIX		?=	/usr/local
 INSTALL_PROGRAM	?=	${INSTALL} -c -s -m 555
@@ -10,6 +11,6 @@
 
 install:
 	${INSTALL_PROGRAM} bsdiff bspatch ${PREFIX}/bin
-.ifndef WITHOUT_MAN
+ifndef WITHOUT_MAN
 	${INSTALL_MAN} bsdiff.1 bspatch.1 ${PREFIX}/man/man1
-.endif
+endif
