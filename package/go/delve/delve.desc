[D] 887cb69a9f4824b483f987c5858ed8ffc14b9bbf435eb31a76a47596 go-delve-v1.26.1.tar.gz https://github.com/go-delve/delve/archive/v1.26.1/

. $base/package/*/*/go-conf.in
export CGO_ENABLED=1
GCC_WRAPPER_BYPASS=1
xsrcdir=delve-$ver
rungo=
var_append makeopt ' ' build
hook_add postmake 5 'install -Dvm 755 dlv $root$bindir/'
