[V] 1.27.0

[D] 435eed6a5e566398fe10c679fd93f5bd13f587cf8b93c5cef55a7a93 go-delve-v1.27.0.tar.gz https://github.com/go-delve/delve/archive/v1.27.0/

. $base/package/*/*/go-conf.in

export CGO_ENABLED=1
GCC_WRAPPER_BYPASS=1
xsrcdir=delve-$ver
rungo=
var_append makeopt ' ' build
hook_add postmake 5 'install -Dvm 755 dlv $root$bindir/'
