if pkgcheck imlib2 X
then
 	menu_begin MENU_PKG_E17 'Enlightenment 17 Options'
		text 'Install prefix for E17 Packages' \
		     SDECFG_PKG_E17_CORE_PREFIX "opt/e17"
	menu_end
