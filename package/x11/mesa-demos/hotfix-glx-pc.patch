--- mesa-demos-9.0.0/meson.build.vanilla	2023-12-01 15:38:39.093118899 +0100
+++ mesa-demos-9.0.0/meson.build	2023-12-01 15:39:37.623120434 +0100
@@ -98,7 +98,7 @@
     required : dep_x11.found())
 endif
 
