if pkgcheck mesa X; then
	menu_begin MENU_PKG_MESA 'Mesa3D Package Options'
		choice SDECFG_PKG_MESA_TARGET linux-dri \
			linux-dri "Target DRI" \
			linux-directfb "Target DirectFB" \
			linux-fbdev "Target Linux Framebuffer"
	menu_end
fi
