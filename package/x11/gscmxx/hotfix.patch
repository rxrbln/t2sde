 i18n ::
-	$(MKPATH) $(PREFIX)/share/gscmxx/i18n
-	@$(MOD_INSTALL) ./share/i18n/ $(PREFIX)/share/gscmxx/i18n/
+	$(MKPATH) $(DESTDIR)$(VENDORPREFIX)/share/gscmxx/i18n
+	@$(MOD_INSTALL) ./share/i18n/ $(DESTDIR)$(VENDORPREFIX)/share/gscmxx/i18n/
 
 END
 	return $postamble;
