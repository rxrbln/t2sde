Allowing to set a default entry for the combo box is often a must.

  - Rene Rebe <rene@exactcode.de>

diff -ur Xdialog-2.1.1/src/interface.c Xdialog-2.1.1-fixed/src/interface.c
--- Xdialog-2.1.1/src/interface.c	2003-03-25 01:21:58.000000000 +0100
+++ Xdialog-2.1.1-fixed/src/interface.c	2006-02-19 12:07:13.554825000 +0100
@@ -1098,6 +1098,8 @@
 	for (i = 0; i < list_size; i++)
 		glist = g_list_append(glist, options[i]);
 	gtk_combo_set_popdown_strings(GTK_COMBO(combo), glist);
+	if (strlen(Xdialog.default_item) != 0)
+		gtk_entry_set_text(GTK_ENTRY(GTK_COMBO(combo)->entry), Xdialog.default_item);
 
 	gtk_entry_set_editable(GTK_ENTRY(Xdialog.widget1), Xdialog.editable);
 
