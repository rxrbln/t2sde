Fix directory lookup for xkb rules on T2.

  - NoTag <notag@t2sde.org>

--- console-setup-1.196/Keyboard/ckbcomp.vanilla	2026-04-19 16:03:22.447538279 +0200
+++ console-setup-1.196/Keyboard/ckbcomp	2026-04-19 16:06:50.145545927 +0200
@@ -49,7 +49,8 @@
     $installdir = '/usr';
 }
 
-my @xdirs = ('/etc/console-setup/ckb',
+my @xdirs = ('/usr/X11R7/share/X11/xkb',
+             '/etc/console-setup/ckb',
              "$installdir/etc/console-setup/ckb",
 	     '/usr/local/share/X11/xkb',
 	     '/usr/share/X11/xkb',
