         }
         else if ( fmt == LDACBT_SMPL_FMT_S32 ){
@@ -263,7 +272,12 @@
                 p_pcm_8+=4;
             }
 #else   /* __BYTE_ORDER */
-#error unsupported byte order
+            for (i = 0; i < nsmpl; i++) {
+                *p_lch_8++ = p_pcm_8[3]; *p_lch_8++ = p_pcm_8[2]; *p_lch_8++ = p_pcm_8[1]; *p_lch_8++ = p_pcm_8[0];
+                p_pcm_8+=4;
