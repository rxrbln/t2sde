@@ -248,7 +248,16 @@
                 p_pcm_8+=3;
             }
 #else   /* __BYTE_ORDER */
-#error unsupported byte order
+            for (i = 0; i < nsmpl; i++) {
+                *p_lch_8++ = p_pcm_8[2];
+                *p_lch_8++ = p_pcm_8[1];
+                *p_lch_8++ = p_pcm_8[0];
