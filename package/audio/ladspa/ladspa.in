#correct some common paths in one place
var_append makeinstopt ' ' "DEST=$root$libdir/ladspa"
var_append makeinstopt ' ' "LADSPA_PREFIX=$root$libdir/ladspa/"
var_append makeinstopt ' ' "INSTALL_PLUGINS_DIR=$root$libdir/ladspa"
var_append makeinstopt ' ' "INSTALL_INCLUDE_DIR=$root$includedir"
var_append makeinstopt ' ' "INSTALL_BINARY_DIR=$root$bindir"
