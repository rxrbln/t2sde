The SDE wrappers take care of the build environment, and
the build scripts do not work in a clean environment.

--- texinfo-4.11/configure.vanilla	2007-09-14 16:10:50.000000000 +0200
+++ texinfo-4.11/configure	2007-09-14 16:12:13.000000000 +0200
@@ -15943,7 +15943,7 @@
   # it gets the wrong CC etc.
   # env -i gives this build host configure a clean environment;
   # consequently, we have to re-initialize $PATH.
-  env -i CC="$BUILD_CC" AR="$BUILD_AR" RANLIB="$BUILD_RANLIB" \
+  CC="${BUILD_CC}" AR="${BUILD_AR}" RANLIB="${BUILD_RANLIB}" \
       PATH="$PATH" \
       tools_only=1 \
     ${confdir}/configure --build=${build} --host=${build} \
