[D] d99ec34dc3f42d137a6d5c1b87e3eccd03571eba9554607c288421df zed-0.231.2.tar.gz https://github.com/zed-industries/zed/archive/refs/tags/v0.231.2/

cargoinstopt=
var_append GCC_WRAPPER_APPEND ' ' "-c?:-L$root`pkgprefix libdir libxcb`"
var_append GCC_WRAPPER_APPEND ' ' */jitterentropy-base.c?-O0:
atstage cross && hook_add postmake 5 "install target/${arch_target}/*/zed $root$bindir"
atstage native && hook_add postmake 5 "install target/*/zed $root$bindir"
