diff -u hexedit/interact.c hexedit-hacked/interact.c
--- hexedit/interact.c	Wed Jun 19 13:55:40 2002
+++ hexedit-hacked/interact.c	Wed Oct  9 12:04:18 2002
@@ -360,6 +360,39 @@
       next_line();
       break;
 
+      /* VI keys */
+    case 'h': 
+      if (!hexOrAscii) {
+	      setTo(key);
+	      break;
+      }
+      backward_char();
+      break;
+
+    case 'l': 
+      if (!hexOrAscii) {
+	      setTo(key);
+	      break;
+      }
+      forward_char();
+      break;
+
+    case 'k': 
+      if (!hexOrAscii) {
+	      setTo(key);
+	      break;
+      }
+      previous_line();
+      break;
+
+    case 'j': 
+      if (!hexOrAscii) {
+	      setTo(key);
+	      break;
+      }
+      next_line();
+      break;
+
     case KEY_UP:
     case CTRL('P'):
       previous_line();
@@ -443,6 +476,14 @@
 
     case CTRL('G'):
     case KEY_F(4):
+      goto_char();
+      break;
+
+    case 'g':
+      if (!hexOrAscii) {
+	      setTo(key);
+	      break;
+      }
       goto_char();
       break;
 
