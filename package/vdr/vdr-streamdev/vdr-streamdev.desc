. $base/package/vdr/*/vdr-plugin-conf.in

vdr_plugin_pm() {
	plugin_register "streamdev-server"
	cp -p streamdev/streamdevhosts.conf $PLUGINDIR/streamdevhosts.conf
}
hook_add postmake 5 vdr_plugin_pm
