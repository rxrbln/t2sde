. $base/package/vdr/*/vdr-conf.in

makeopt=
makeinstopt=

pkgprefix -t vdr-text2skin
vdr_skin_pm() {
	tar $taropt $(match_source_file -p $xsrctar) -C $PLUGINDIR/text2skin
}
hook_add postmake 5 'vdr_skin_pm'
