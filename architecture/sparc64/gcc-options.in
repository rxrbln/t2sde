case "$SDECFG_SPARC64_OPT" in
    generic) ;;
    *)
        var_append GCC_WRAPPER_INSERT " " "-mcpu=$SDECFG_SPARC64_OPT"
        var_append KCC_WRAPPER_APPEND " " "-mcpu=$SDECFG_SPARC64_OPT" ;;
esac
