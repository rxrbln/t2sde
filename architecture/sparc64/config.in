#Description: SPARC 64 (Sun Ultra SPARC, Fujitsu)

choice SDECFG_SPARC64_OPT generic   \
	generic		"No special optimization"		\
	ultrasparc	"Optimized for Sun UltraSPARC"		\
	ultrasparc3	"Optimized for Sun UltraSPARC III/III+/IIIi/IIIi+/IV/IV+"	\
	niagara		"Optimized for Sun T1 (Niagara)"	\
	niagara2	"Optimized for Sun T2 (Niagara 2)"	\
	niagara3	"Optimized for Sun T3 (Niagara 3)"	\
	niagara4	"Optimized for Sun T4 (Niagara 4)"	\
	niagara7	"Optimized for Oracle M7 (Niagara 7)"	\
	m8		"Optimized for Oracle M8"

bool 'Default to 32bit for the user-space applications' SDECFG_SPARC64_32BIT 1

SDECFGSET_MULTILIB=1
SDECFG_ID="$SDECFG_ID-$SDECFG_SPARC64_OPT"
[ "$SDECFG_SPARC64_32BIT" = 1 ] && SDECFG_ID="$SDECFG_ID-32"

. architecture/sparc/boot-config.in
