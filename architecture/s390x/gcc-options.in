if [ "$SDECFG_S390X_OPT" != "generic" ] ; then
	var_append GCC_WRAPPER_INSERT " " "-march=$SDECFG_S390X_OPT"
	var_append KCC_WRAPPER_APPEND " " "-march=$SDECFG_S390X_OPT"
fi
