if [ "$SDECFG_SH_OPT" ] ; then
	opt=""
	case "$SDECFG_SH_OPT" in
		sh) opt="-m1" ;;
		sh2) opt="-m2" ;;
		sh3) opt="-m3" ;;
		sh4) opt="-m4" ;;
	esac
	var_append GCC_WRAPPER_INSERT " " "$opt" 
	#var_append KCC_WRAPPER_APPEND " " "$opt" 
fi
