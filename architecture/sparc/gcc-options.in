if [ "$SDECFG_SPARC_OPT" ]; then
	case "$SDECFG_SPARC_OPT" in
		v9vis)	var_append GCC_WRAPPER_INSERT " " "-mcpu=v9 -mvis"
			var_append KCC_WRAPPER_APPEND " " "-mcpu=v9"
			;;
		*)	var_append GCC_WRAPPER_INSERT " " "-mcpu=$SDECFG_SPARC_OPT"
			var_append KCC_WRAPPER_APPEND " " "-mcpu=$SDECFG_SPARC_OPT"
			;;
	esac
fi
