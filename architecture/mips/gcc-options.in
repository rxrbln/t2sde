if [ $SDECFG_MIPS_OPT != generic ]; then
	var_append GCC_WRAPPER_INSERT " " "-march=$SDECFG_MIPS_OPT"
	#var_append KCC_WRAPPER_APPEND " " "-march=$SDECFG_MIPS_OPT"
fi
var_append GCC_WRAPPER_APPEND " " "-${SDECFG_MIPS_ENDIANESS}"
