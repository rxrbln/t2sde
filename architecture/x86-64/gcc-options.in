case "$SDECFG_X8664_OPT" in
    generic) ;;
    *)
	var_append GCC_WRAPPER_INSERT " " "-march=$SDECFG_X8664_OPT"
	var_append KCC_WRAPPER_APPEND " " "-march=$SDECFG_X8664_OPT"
	;;
esac
