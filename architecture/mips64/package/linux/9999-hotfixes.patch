 	IMP_CFIFOW(MMIO) = 0x000e0100;
-	while (IMP_DMABUSY(MMIO) & 0x1eff)
+	while (IMP_RD32(IMP_DMABUSY(MMIO)) & 0x1eff)
 		cpu_relax();
 
