if [ $SDECFG_MIPS64_OPT != generic ]; then
	var_append GCC_WRAPPER_INSERT " " "-march=$SDECFG_MIPS64_OPT"
	#var_append KCC_WRAPPER_APPEND " " "-march=$SDECFG_MIPS64_OPT"
fi
