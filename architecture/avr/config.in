#Description: AVR (Atmel)

choice SDECFG_AVR_OPT default \
	default		"No special optimization"

if [ $SDECFG_AVR_OPT != default ]; then
	SDECFG_ID="$SDECFG_ID-$SDECFG_AVR_OPT"
fi

# Force avr-libc system library
SDECFGSET_LIBC='avr-libc'
