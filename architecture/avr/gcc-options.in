if [ "$SDECFG_AVR_OPT" != "default" ] ; then
	var_append GCC_WRAPPER_INSERT " " "-mcpu=$SDECFG_AVR_OPT"
	#var_append KCC_WRAPPER_APPEND " " "-mcpu=$SDECFG_AVR_OPT"
fi
