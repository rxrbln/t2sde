# TODO: wire up all kinds of RV32 variants (probably shared w/ RV64)

if [ "$SDECFG_SOFTFLOAT" = 1 ]; then
	# rv32gc (rc32imafdc), gcv (Zv*) Zb* finx
	var_append GCC_WRAPPER_INSERT " " "-march=rv32imac"
	var_append KCC_WRAPPER_APPEND " " "-march=rv32imac"
fi
