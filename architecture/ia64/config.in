#Description: IA-64 (Intel Itanium)

# gcc-4.5: Support has been removed for tuning for Itanium1, ...
choice SDECFG_IA64_OPT itanium2				\
	itanium2	"Optimized for Itanium2"

SDECFG_ID="$SDECFG_ID-$SDECFG_IA64_OPT"
