if [ "$SDECFG_POWERPC_OPT" != "generic" ] ; then
	var_append GCC_WRAPPER_INSERT " " "-mcpu=$SDECFG_POWERPC_OPT"
	var_append KCC_WRAPPER_APPEND " " "-mcpu=$SDECFG_POWERPC_OPT"
fi
