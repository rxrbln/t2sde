comment ' '
comment_id '- Package distribution destination' COMMENT_PKGDIST

block_begin 7
	comment 'If all following fields are empty, nothing is done.'

	text "Package destination" SDECFG_TARGET_PKGDIST_LOCATION ''
	text "Username" SDECFG_TARGET_PKGDIST_USER ''
	text "Password" SDECFG_TARGET_PKGDIST_PASS ''
block_end
