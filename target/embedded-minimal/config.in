#Description: Embedded Minimal

SDECFGSET_INIT='busybox'

SDECFGSET_OPT='size'

SDECFGSET_DO_REBUILD_STAGE=0
SDECFGSET_CROSSBUILD=1
SDECFGSET_DISABLE_NLS=1

SDECFGSET_LIBC="uclibc"
