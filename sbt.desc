[I] A simple build tool

[T] Sbt is a build tool built for Scala and Java projects.

[U] https://www.scala-sbt.org/

[A] Scala Center
[M] René Rebe <rene@exactco.de>

[C] base/development
[F] CROSS

[L] APL
[V] 1.12.11

[D] b1282471a0830a9392d1364dfb25cf29d0ea86ca2b854560f3e4a042 sbt-1.12.11.tar.gz https://github.com/sbt/sbt/archive/refs/tags/v1.12.11/

runmake=0

build() {
	./sbt \
		-Dsbt.build.version=1.12.11 \
		-Dsbt.build.offline=false \
		clean \
		launcherPackage/Universal/packageBin \
		launcherPackage/Universal/packageZipTarball
}
hook_add inmake 5 build

install() {
	mkdir -p $root/opt
	tar -xf launcher-package/target/universal/sbt.tgz -C $root/opt

	mkdir -p $root$bindir
	ln -sf $root/opt/sbt/bin/sbt $root$bindir/sbt

	mkdir -p $root/etc/sbt
	cp -f $root/opt/sbt/conf/sbtopts $root/etc/sbt/sbtopts
}
hook_add postmake 5 install
